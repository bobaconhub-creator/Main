local Tabs = {}
local function CreateTab(name, order)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0.333, 0, 1, 0)
    Button.BackgroundTransparency = 1
    Button.Text = name
    Button.Font = Enum.Font.SourceSansBold
    Button.TextSize = 14
    Button.TextColor3 = Color3.fromRGB(100, 100, 100)
    Button.LayoutOrder = order
    Button.Parent = TabBar

    local Page = Instance.new("Frame")
    Page.Size = UDim2.new(1, -20, 1, -20)
    Page.Position = UDim2.new(0, 10, 0, 10)
    Page.BackgroundTransparency = 1
    Page.Visible = (order == 1)
    Page.Parent = ContentFrame

    if order == 1 then Button.TextColor3 = Color3.fromRGB(0, 0, 0) end

    Button.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do
            t.Page.Visible = false
            t.Btn.TextColor3 = Color3.fromRGB(100, 100, 100)
        end
        Page.Visible = true
        Button.TextColor3 = Color3.fromRGB(0, 0, 0)
    end)

    Tabs[name] = {Page = Page, Btn = Button}
    return Page
end

