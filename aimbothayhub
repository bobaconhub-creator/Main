-- Hàm tạo cấu trúc đồ họa ESP cho Player mới
local function CreateESP(player)
    if ESP_Cache[player] then return end
    
    local Box = Drawing.new("Square")
    Box.Thickness = 1
    Box.Filled = false
    Box.Color = Color3.fromRGB(255, 255, 255)
    
    local Line = Drawing.new("Line")
    Line.Thickness = 1
    Line.Color = Color3.fromRGB(255, 255, 255)

    ESP_Cache[player] = {Box = Box, Line = Line}
end

local function RemoveESP(player)
    if ESP_Cache[player] then
        ESP_Cache[player].Box:Remove()
        ESP_Cache[player].Line:Remove()
        ESP_Cache[player].Nil = nil
    end
end

Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end

------------------------------------------------------------------------
-- VÒNG LẶP CHÍNH CẬP NHẬT TỌA ĐỘ (RENDERSTEPPED HƠN HEARTBEAT)
------------------------------------------------------------------------
-- Tìm mục tiêu gần nhất thoả mãn điều kiện
local function GetClosestTarget()
    local target = nil
    local maxDist = Config.FOV
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            if Config.TeamCheck and player.Team == LocalPlayer.Team then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < maxDist then
                    maxDist = dist
                    target = player.Character.HumanoidRootPart
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    
    -- Cập nhật FOV tròn phát sáng Aura
    if Config.Aimbot then
        FOVCircle.Position = mousePos
        FOVCircle.Radius = Config.FOV
        FOVCircle.Visible = true
        
        -- Thực thi Khóa tâm lập tức (Instant Lock)
        local target = GetClosestTarget()
        if target then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    else
        FOVCircle.Visible = false
    end

    -- Cập nhật Vẽ ESP (Box + Tracer Line)
    for player, draw in pairs(ESP_Cache) do
        if Config.ESP and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local rootPart = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
            
            if onScreen then
                -- Tính toán kích thước Khung 2D tương thích theo khoảng cách xa gần
                local head = player.Character:FindFirstChild("Head")
                local headPos = head and Camera:WorldToViewportPoint(head.Position) or pos
                local width = (pos.Y - headPos.Y) * 2
                local height = width * 1.5
                
                draw.Box.Size = Vector2.new(width, height)
                draw.Box.Position = Vector2.new(pos.X - width/2, pos.Y - height/2)
                draw.Box.Visible = true

                -- Vẽ đường kẻ Tracer phát ra từ đáy màn hình của bạn
                draw.Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                draw.Line.To = Vector2.new(pos.X, pos.Y)
                draw.Line.Visible = true
            else
                draw.Box.Visible = false
                draw.Line.Visible = false
            end
        else
            draw.Box.Visible = false
            draw.Line.Visible = false
        end
    end
end)
