    local function canSee(targetPart)
        if not wallCheck then return true end
        local rayParams=RaycastParams.new()
        rayParams.FilterDescendantsInstances={player.Character}
        rayParams.FilterType=Enum.RaycastFilterType.Blacklist

        local ray=Workspace:Raycast(
            Camera.CFrame.Position,
            targetPart.Position-Camera.CFrame.Position,
            rayParams
        )

        if ray and ray.Instance and not ray.Instance:IsDescendantOf(targetPart.Parent) then
            return false
        end
        return true
    end

    local function getClosestTarget()
        local center=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
        local fov=tonumber(FOVBox.Text) or 100

        if priorityTarget and priorityTarget.Character then
            local tPart = getTargetPart(priorityTarget.Character)
            local hum=priorityTarget.Character:FindFirstChildOfClass("Humanoid")
            if tPart and hum and hum.Health>0 then
                local pos,onScreen=Camera:WorldToViewportPoint(tPart.Position)
                if onScreen then
                    local dist2d=(Vector2.new(pos.X,pos.Y)-center).Magnitude
                    if dist2d<=fov and canSee(tPart) then
                        return priorityTarget
                    end
                end
            end
        end

        local closest=nil
        local shortest=math.huge

        for _,plr in pairs(Players:GetPlayers()) do
            if plr~=player and plr.Character then
                local tPart = getTargetPart(plr.Character)
                local humanoid=plr.Character:FindFirstChildOfClass("Humanoid")

                if tPart and humanoid and humanoid.Health>0 then
                    if (not friendCheck or not player:IsFriendsWith(plr.UserId)) and
                       (not teamCheck or plr.Team~=player.Team) then

                        if teamNumCheck then
                            local a = plr:GetAttribute("TeamNum")
                            local b = player:GetAttribute("TeamNum")
                            if a and b and a == b then
                                continue
                            end
                        end

                        local screenPos,onScreen=Camera:WorldToViewportPoint(tPart.Position)

                        if onScreen then
                            local dist2d=(Vector2.new(screenPos.X,screenPos.Y)-center).Magnitude

                            if dist2d<=fov and dist2d<shortest and canSee(tPart) then
                                shortest=dist2d
                                closest=plr
                            end
                        end
                    end
                end
            end
        end

        if closest then
            return closest
        end

        if aimNPC then
            local closestNPC=nil
            local shortestNPC=math.huge

            for _,npc in pairs(Workspace:GetDescendants()) do
                if npc:IsA("Model") and npc:FindFirstChild("Humanoid") then
                    local tPart = getTargetPart(npc)
                    if tPart and Players:GetPlayerFromCharacter(npc)==nil then
                        local hum=npc.Humanoid
                        if hum.Health>0 then
                            if teamNumCheck then
                                local npcNum = npc:GetAttribute("TeamNum")
                                local playerNum = player:GetAttribute("TeamNum")
                                if npcNum and playerNum and npcNum == playerNum then
                                    continue
                                end
                            end

                            local screenPos,onScreen=Camera:WorldToViewportPoint(tPart.Position)

                            if onScreen then
                                local dist=(Vector2.new(screenPos.X,screenPos.Y)-center).Magnitude

                                if dist<=fov and dist<shortestNPC and canSee(tPart) then
                                    shortestNPC=dist
                                    closestNPC=npc
                                end
                            end
                        end
                    end
                end
            end

            return closestNPC
        end

        return nil
    end

    RunService.RenderStepped:Connect(function()
        FOVCircle.Position=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
        FOVCircle.Radius=tonumber(FOVBox.Text) or 100

        if espOn then
            espDistance=tonumber(ESPDistBox.Text) or 100

            for _,plr in pairs(Players:GetPlayers()) do
                if plr~=player and plr.Character then
                    local tPart = getTargetPart(plr.Character)
                    local humanoid=plr.Character:FindFirstChildOfClass("Humanoid")

                    if tPart and humanoid and humanoid.Health>0 then
                        if not espLines[plr] then
                            espLines[plr]=Drawing.new("Line")
                            espLines[plr].Thickness=2
                        end

                        local screenPos,onScreen=Camera:WorldToViewportPoint(tPart.Position)
                        local line=espLines[plr]

                        if player.Character and getTargetPart(player.Character) then
                            local myPart = getTargetPart(player.Character)
                            local dist=(myPart.Position-tPart.Position).Magnitude

                            if onScreen and dist<=espDistance then
                                line.Visible=true
                                line.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                                line.To=Vector2.new(screenPos.X,screenPos.Y)

                                if player:IsFriendsWith(plr.UserId) then
                                    line.Color=Color3.fromRGB(0,255,0) -- Bạn bè giữ màu xanh lá
                                else
                                    line.Color=Color3.fromRGB(255, 255, 255) -- Đổi ESP Line kẻ địch sang màu trắng
                                end
                            else
                                line.Visible=false
                            end
                        end
                    end
                end
            end
        end

        if aimOn then
            local target=getClosestTarget()

            if target then
                local targetBodyPart=nil

                if target:IsA("Player") then
                    if target.Character then
                        targetBodyPart=getTargetPart(target.Character)
                    end
                else
                    targetBodyPart=getTargetPart(target)
                end

                if targetBodyPart then
                    -- Ngắm thẳng vào Thân thay vì Đầu
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetBodyPart.Position)

                    if autoShot then
                        if tick() - lastAutoShot >= autoShotInterval then
                            lastAutoShot = tick()
                            pcall(function()
                                if player.Character then
                                    local tool = player.Character:FindFirstChildOfClass("Tool")
                                    if tool and tool.Parent then
                                        tool:Activate()
                                    end
                                end
                             pcall_end)
                        end
                    end
                end
            end
        end
    end)

