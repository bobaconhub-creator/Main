task.spawn(function()
    local url = "https://raw.githubusercontent.com/vukk2k12-hub/vukk/refs/heads/main/Code"
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and response then
        -- Chuyển toàn bộ dữ liệu phản hồi sang chữ thường để kiểm tra từ khóa linh hoạt
        local lowResponse = string.lower(response)
        local isShowTab7 = string.find(lowResponse, "true") ~= nil
        
        -- NẾU TRONG LINK CHỨA TỪ KHÓA TRUE, TAB 7 SẼ ĐƯỢC TẠO
        if isShowTab7 then
            createTab("Mã Code Mới", 400)
            local Tab7Btn = addTabButton("Mã Code Mới", 7)
            local Tab7Scroll = Tabs["Mã Code Mới"].Scroll
            
            -- Tiêu đề của Tab 7
            local Header = Instance.new("TextLabel", Tab7Scroll)
            Header.Size = UDim2.new(1, -20, 0, 35)
            Header.Position = UDim2.new(0, 10, 0, 10)
            Header.BackgroundTransparency = 1
            Header.Text = "📋 DANH SÁCH MÃ CODE MỚI CẬP NHẬT"
            Header.TextColor3 = Color3.fromRGB(130, 20, 200)
            Header.Font = Enum.Font.GothamBold
            Header.TextSize = 13
            Header.TextXAlignment = Enum.TextXAlignment.Left
            
            -- Khởi chạy quá trình quét và lọc toàn bộ các dòng chữ chứa thông tin code dạng vd `newbie:1`
            local lines = string.split(response, "\n")
            local yPos = 50
            
            for _, line in pairs(lines) do
                -- Loại bỏ khoảng trắng thừa đầu cuối dòng
                local cleanLine = string.gsub(line, "^%s*(.-)%s*$", "%1")
                
                -- Chỉ hiển thị những dòng không phải là từ khóa true/false thuần túy hay cấu hình cũ
                if cleanLine ~= "" and not string.find(string.lower(cleanLine), "so coins:") and not string.find(string.lower(cleanLine), "so lan dc nhap:") and cleanLine ~= "true" and cleanLine ~= "false" then
                    
                    local CodeLabel = Instance.new("TextLabel", Tab7Scroll)
                    CodeLabel.Size = UDim2.new(1, -30, 0, 35)
                    CodeLabel.Position = UDim2.new(0, 15, 0, yPos)
                    CodeLabel.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
                    CodeLabel.TextColor3 = Color3.fromRGB(50, 50, 50)
                    CodeLabel.TextSize = 13
                    CodeLabel.Font = Enum.Font.GothamBold
                    CodeLabel.Text = "  🔑 Code: " .. cleanLine
                    CodeLabel.TextXAlignment = Enum.TextXAlignment.Left
                    Instance.new("UICorner", CodeLabel).CornerRadius = UDim.new(0, 6)
                    
                    yPos = yPos + 42
                end
            end
            
            -- Tự động điều chỉnh kích thước cuộn của Tab 7 dựa trên lượng code tìm thấy
            Tab7Scroll.CanvasSize = UDim2.new(0, 0, 0, yPos + 20)
        else
            warn("[BaconHub Code System] Link GitHub chứa 'false'. Không kích hoạt Tab 7.")
        end
    end
end)

