-- Nhận lệnh chat ẩn/hiện mục tiêu khỏi hệ thống visual (Blacklist lệnh lhb / ulhb)
local function listenToChat(p)
    p.Chatted:Connect(function(msg)
        local args = string.split(msg, " ")
        if args[1] and args[2] then
            local cmd = args[1]:lower()
            local targetName = args[2]
            local targetPlayer = nil
            for _, pl in pairs(players:GetPlayers()) do
                if pl.Name:lower():sub(1, #targetName) == targetName:lower() then
                    targetPlayer = pl
                    break
                end
            end
            if targetPlayer then
                if cmd == "lhb" then
                    settings.Blacklist[targetPlayer.Name] = true
                    refreshPlayerVisuals(targetPlayer) 
                elseif cmd == "ulhb" then
                    settings.Blacklist[targetPlayer.Name] = nil
                    refreshPlayerVisuals(targetPlayer) 
                end
            end
        end
    end)
end

for _, p in pairs(players:GetPlayers()) do
    if p ~= player then
        listenToChat(p)
        p.CharacterAdded:Connect(function() task.wait(0.1) refreshPlayerVisuals(p) end)
    end
end

players.PlayerAdded:Connect(function(p)
    playerCache[p.UserId] = { team = p.Team }
    listenToChat(p)
    p.Changed:Connect(function(prop) if prop == "Team" then updatePlayerTeamStatus(p) end end)
    p.CharacterAdded:Connect(function() task.wait(0.1) refreshPlayerVisuals(p) end)
end)
players.PlayerRemoving:Connect(function(p) playerCache[p.UserId] = nil end)

