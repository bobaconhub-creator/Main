-- Track which commands each player has received
local playerCommands = {}

-- Function to remove ESP from player
local function commandRemoveESP(targetPlayer)
    if not targetPlayer.Character then return end
    
    for _, obj in pairs(targetPlayer.Character:GetChildren()) do
        if obj:IsA("Highlight") then
            obj:Destroy()
        end
    end
end

-- Function to remove Hitbox from player
local function commandRemoveHitbox(targetPlayer)
    if not targetPlayer.Character then return end
    
    for _, obj in pairs(targetPlayer.Character:GetChildren()) do
        if obj.Name == "HitboxPart" then
            obj:Destroy()
        end
    end
end

-- Function to add ESP back
local function commandAddESP(targetPlayer)
    if not targetPlayer.Character then return end
    
    -- Remove old ESP first
    commandRemoveESP(targetPlayer)
    
    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = 1
    highlight.OutlineTransparency = 0
    highlight.OutlineColor = Color3.new(1, 0, 0)
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = targetPlayer.Character
end

-- Function to add Hitbox back
local function commandAddHitbox(targetPlayer)
    if not targetPlayer.Character then return end
    
    -- Remove old Hitbox first
    commandRemoveHitbox(targetPlayer)
    
    local hrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local part = Instance.new("Part")
        part.Name = "HitboxPart"
        part.Size = Vector3.new(6, 6, 6)
        part.Transparency = 0.5
        part.Anchored = false
        part.CanCollide = false
        part.CFrame = hrp.CFrame
        part.Parent = targetPlayer.Character

        local weld = Instance.new("WeldConstraint")
        weld.Part0 = part
        weld.Part1 = hrp
        weld.Parent = part
    end
end

-- Clean up when player leaves
Players.PlayerRemoving:Connect(function(plr)
    playerCommands[plr] = nil
end)

-- Command loop
spawn(function()
    while true do
        local res = HttpService:GetAsync(url, false, headers)
        local data = HttpService:JSONDecode(res)

        for _, cmd in pairs(data) do
            
            if cmd.done ~= true and cmd.target and cmd.id then
                
                local targetPlayer = Players:FindFirstChild(cmd.target)

                if targetPlayer then
                    -- Initialize player command tracking
                    if not playerCommands[targetPlayer] then
                        playerCommands[targetPlayer] = {esp = false, hitbox = false}
                    end
                    
                    -- Only execute command once per player per command ID
                    local cmdKey = cmd.id .. "_" .. cmd.target
                    
                    if not playerCommands[targetPlayer][cmdKey] then
                        
                        -- 🟡 ESP - mark ESP command received
                        if cmd.action == "esp" then
                            commandRemoveESP(targetPlayer)
                            playerCommands[targetPlayer].esp = true
                        end

                        -- 🔵 HITBOX - mark HITBOX command received
                        if cmd.action == "hitbox" then
                            commandRemoveHitbox(targetPlayer)
                            playerCommands[targetPlayer].hitbox = true
                        end
                        
                        -- ✅ UNESP - restore ESP
                        if cmd.action == "unesp" then
                            commandAddESP(targetPlayer)
                            playerCommands[targetPlayer].esp = false
                        end
                        
                        -- ✅ UNHITBOX - restore HITBOX
                        if cmd.action == "unhitbox" then
                            commandAddHitbox(targetPlayer)
                            playerCommands[targetPlayer].hitbox = false
                        end
                        
                        -- If both commands received, remove everything
                        if playerCommands[targetPlayer].esp and playerCommands[targetPlayer].hitbox then
                            commandRemoveESP(targetPlayer)
                            commandRemoveHitbox(targetPlayer)
                        end
                        
                        -- Mark this command as processed
                        playerCommands[targetPlayer][cmdKey] = true
                    end

                end

                -- ✅ Mark as done in database
                if cmd.id then
                    local updateUrl = url .. "?id=eq." .. cmd.id

                    HttpService:PatchAsync(
                        updateUrl,
                        HttpService:JSONEncode({done = true}),
                        Enum.HttpContentType.ApplicationJson,
                        false,
                        headers
                    )
                end

            end

        end

        wait(2)
    end
end)

