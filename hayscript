        return game:HttpGet("https://raw.githubusercontent.com/vukk2k12-hub/vukk/refs/heads/main/Code")
    end)
    
    if not success then
        CodeInput.Text = ""
        CodeInput.PlaceholderText = "Lỗi kết nối máy chủ dữ liệu!"
        return
    end
    
    local isFound = false
    for line in string.gmatch(content, "[^\r\n]+") do
        local parts = string.split(line, ":")
        if #parts >= 4 then
            local cCode = parts[1]:lower():gsub("%s+", "")
            local cCoins = tonumber(parts[2]) or 0
            local cMaxClaims = tonumber(parts[3]) or 0
            
            if text == cCode then
                isFound = true
                local currentClaims = settings.RedeemedCodes[cCode] or 0
                if currentClaims < cMaxClaims then
                    settings.Coins = settings.Coins + cCoins
                    settings.RedeemedCodes[cCode] = currentClaims + 1
                    updateCoinsUI()
                    saveVIPData()
                    CodeInput.Text = ""
                    CodeInput.PlaceholderText = "Thành công! +" .. cCoins .. " Xu"
                else
                    CodeInput.Text = ""
                    CodeInput.PlaceholderText = "Mã này đã hết lượt nhập!"
                end
                break
            end
        end
    end
    
    if not isFound then
        CodeInput.Text = ""
        CodeInput.PlaceholderText = "Mã code không hợp lệ!"
    end
end)

