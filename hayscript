local function getToday()
    local now = os.date("*t")
    return string.format("%d-%d-%d", now.day, now.month, now.year)
end

local function isEventTimeValid(timeString)
    if not timeString or timeString == "" then return false end
    
    local now = os.date("*t")
    local currentMinutes = now.hour * 60 + now.min
    local currentDay = now.day
    local currentMonth = now.month
    local currentYear = now.year
    
    local parts = {}
    for part in string.gmatch(timeString, "[^:]+") do
        table.insert(parts, part)
    end
    
    local isHourValid = false
    local isDateValid = false
    
    for _, part in ipairs(parts) do
        local hourMatch = string.match(part, "^(%d+)%.(%d+)-(%d+)%.(%d+)$")
        if hourMatch then
            local startH, startM, endH, endM = tonumber(hourMatch), tonumber(hourMatch), tonumber(hourMatch), tonumber(hourMatch)
            local startMinutes = startH * 60 + startM
            local endMinutes = endH * 60 + endM
            
            if startMinutes <= endMinutes then
                isHourValid = (currentMinutes >= startMinutes and currentMinutes <= endMinutes)
            else
                isHourValid = (currentMinutes >= startMinutes or currentMinutes <= endMinutes)
            end
        end
        
        local dateMatch = string.match(part, "^(%d+)/(%d+)/(%d+)-(%d+)/(%d+)/(%d+)$")
        if dateMatch then
            local startD, startM, startY, endD, endM, endY = tonumber(dateMatch), tonumber(dateMatch), tonumber(dateMatch), tonumber(dateMatch), tonumber(dateMatch), tonumber(dateMatch)
            local startDate = os.time({day=startD, month=startM, year=startY})
            local endDate = os.time({day=endD, month=endM, year=endY})
            local nowTime = os.time()
            
            isDateValid = (nowTime >= startDate and nowTime <= endDate)
        end
    end
    
    return isHourValid and isDateValid
end

