--------------------------------------------------
-- RESET HITBOX

local function resetHitbox(plr)

    local char = plr.Character

    if char and char:FindFirstChild("HumanoidRootPart") then

        local hrp = char.HumanoidRootPart

        if OriginalSizes[plr] then
            hrp.Size = OriginalSizes[plr]
        else
            hrp.Size = Vector3.new(2,2,1)
        end

        hrp.Transparency = 1
        hrp.CanCollide = true
    end
end

--------------------------------------------------
-- APPLY HITBOX

local function applyHitbox(plr)

    local char = plr.Character

    if char and char:FindFirstChild("HumanoidRootPart") then

        local hrp = char.HumanoidRootPart

        if not OriginalSizes[plr] then
            OriginalSizes[plr] = hrp.Size
        end

        local size = settings.HitboxSize

        hrp.Size = Vector3.new(size, size, size)
        hrp.Transparency = 0.5
        hrp.CanCollide = false
    end
end

--------------------------------------------------
-- ESP

local function getESP(plr)
    return ESPFolder:FindFirstChild(plr.Name)
end

local function createESP(plr,enemy)

    if getESP(plr) then
        return
    end

    local hl = Instance.new("Highlight")

    hl.Name = plr.Name
    hl.Adornee = plr.Character
    hl.FillTransparency = 1
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

    if enemy then
        hl.OutlineColor = Color3.fromRGB(255,0,0)
    else
        hl.OutlineColor = Color3.fromRGB(0,255,0)
    end

    hl.Parent = ESPFolder
    
    -- Add name/health label if enabled
    if settings.ESPNameShow or settings.ESPHealthShow then
        local billboardGui = Instance.new("BillboardGui")
        billboardGui.Name = "Label_" .. plr.Name
        billboardGui.Size = UDim2.new(4, 0, 2, 0)
        billboardGui.MaxDistance = math.huge
        billboardGui.Parent = plr.Character
        
        local textLabel = Instance.new("TextLabel")
        textLabel.BackgroundTransparency = 0.3
        textLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.TextColor3 = enemy and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
        textLabel.TextSize = 14
        textLabel.Font = Enum.Font.GothamBold
        textLabel.Parent = billboardGui
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        
        local displayText = ""
        if settings.ESPNameShow then
            displayText = plr.Name
        end
        if settings.ESPHealthShow and plr.Character:FindFirstChild("Humanoid") then
            if displayText ~= "" then
                displayText = displayText .. " | " .. tostring(math.floor(plr.Character.Humanoid.Health)) .. "HP"
            else
                displayText = tostring(math.floor(plr.Character.Humanoid.Health)) .. "HP"
            end
        end
        
        textLabel.Text = displayText
    end
end

local function removeESP(plr)

    local esp = getESP(plr)

    if esp then
        esp:Destroy()
    end
    
    local label = ESPFolder.Parent:FindFirstChild("Label_" .. plr.Name)
    if label then
        label:Destroy()
    end
end

