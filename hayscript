        end
        
        if dist < 3 then
            indicator:Destroy()
            connection:Disconnect()
        end
    end)
    
    return connection
end

local function startCoinGame()
    if CoinGameActive then return end
    CoinGameActive = true
    FoundCoins = {}
    CoinParts = {}
    CoinGameConnections = {}
    
    MainFrame.Visible = false
    
    local playerPos = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not playerPos then
        MainFrame.Visible = true
        CoinGameActive = false
        return
    end
    
    local center = playerPos.Position
    local radius = 300
    
    local coinPositions = {}
    for i = 1, 10 do
        local angle = math.random() * 2 * math.pi
        local distance = math.random(50, radius)
        local x = center.X + math.cos(angle) * distance
        local z = center.Z + math.sin(angle) * distance
        
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {workspace}
        rayParams.FilterType = Enum.RaycastFilterType.Blacklist
        
        local ray = Ray.new(Vector3.new(x, center.Y + 100, z), Vector3.new(0, -200, 0))
        local result = workspace:Raycast(ray.Origin, ray.Direction, rayParams)
        
        local y = center.Y
        if result then
            y = result.Position.Y + 2
        end
        
        table.insert(coinPositions, Vector3.new(x, y, z))
    end
    
    local screenGui, progressLabel, exitBtn = createProgressUI()
    CoinGameUI.screenGui = screenGui
    CoinGameUI.progressLabel = progressLabel
    
    for i, pos in ipairs(coinPositions) do
        local coin, spinConn, floatConn, glow = createCoin(pos)
        CoinParts[i] = coin
        table.insert(CoinGameConnections, spinConn)
        table.insert(CoinGameConnections, floatConn)
        
        local indicatorConn = createCoinIndicator(coin, player.Character)
        if indicatorConn then
            table.insert(CoinGameConnections, indicatorConn)
        end
        
        local touchPart = Instance.new("Part")
        touchPart.Size = Vector3.new(1.5, 0.5, 1.5)
        touchPart.Position = pos
        touchPart.Anchored = true
        touchPart.CanCollide = false
        touchPart.Transparency = 1
        touchPart.Parent = workspace
        
        local touchConnection = touchPart.Touched:Connect(function(hit)
            if not CoinGameActive then return end
            if hit and hit.Parent and hit.Parent:FindFirstChild("Humanoid") then
                local humanoid = hit.Parent:FindFirstChild("Humanoid")
                if humanoid and humanoid == player.Character.Humanoid then
                    if not FoundCoins[i] then
                        FoundCoins[i] = true
                        
                        coin.Transparency = 1
                        glow.Enabled = false
                        touchPart:Destroy()
                        
                        local found = 0
                        for _, v in pairs(FoundCoins) do
                            if v then found = found + 1 end
                        end
                        progressLabel.Text = "🪙 Tìm xu: " .. found .. "/10"
                        
                        if found >= 10 then
                            local reward = 100 * settings.Multiplier
                            settings.Coins = settings.Coins + reward
                            updateCoinsUI()
                            saveVIPData()
                            
                            progressLabel.Text = "✅ Thành công! +" .. reward .. " 💸"
                            progressLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                            
                            task.wait(2)
                            endCoinGame()
                        end
                    end
                end
            end
        end)
        
        table.insert(CoinGameConnections, touchConnection)
    end
    
    exitBtn.MouseButton1Click:Connect(function()
        endCoinGame()
    end)
    
    local distanceCheck = game:GetService("RunService").Heartbeat:Connect(function()
        if not CoinGameActive then
            distanceCheck:Disconnect()
            return
        end
        
        local currentPos = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if currentPos then
            local dist = (currentPos.Position - center).Magnitude
            if dist > radius + 50 then
                progressLabel.Text = "⚠️ Đã ra khỏi khu vực! Quay lại!"
                progressLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            else
                if progressLabel.TextColor3 ~= Color3.fromRGB(255, 215, 0) then
                    progressLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
                end
            end
        end
    end)
    table.insert(CoinGameConnections, distanceCheck)
end

local function endCoinGame()
    if not CoinGameActive then return end
    CoinGameActive = false
    
    for _, coin in pairs(CoinParts) do
        if coin and coin.Parent then
            coin:Destroy()
        end
    end
    
    for _, conn in pairs(CoinGameConnections) do
        if conn and conn.Disconnect then
            pcall(function() conn:Disconnect() end)
        end
    end
    
    if CoinGameUI.screenGui and CoinGameUI.screenGui.Parent then
        CoinGameUI.screenGui:Destroy()
    end
    
    CoinParts = {}
    CoinGameConnections = {}
    CoinGameUI = {}
    
    MainFrame.Visible = true
    showTab("Coins Ads")
end

