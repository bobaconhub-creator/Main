local DailyRewards = {}
local dailyRewardItems = {}
local lastClaimDate = ""
local currentStreak = 0
local isClaiming = false

local function getToday()
    local now = os.date("*t")
    return string.format("%d-%d-%d", now.day, now.month, now.year)
end

local function loadDailyRewards()
    pcall(function()
        local res = game:HttpGet("https://raw.githubusercontent.com/vukk2k12-hub/vukk/refs/heads/main/dayli")
        DailyRewards = {}
        
        for line in res:gmatch("[^\r\n]+") do
            local split = string.split(line, ":")
            if #split == 2 then
                local coins = tonumber(split[1]) or 0
                local day = tonumber(split[2]) or 0
                if day >= 1 and day <= 30 then
                    table.insert(DailyRewards, {
                        day = day,
                        coins = coins
                    })
                end
            end
        end
        
        if #DailyRewards == 0 then
            for day = 1, 30 do
                table.insert(DailyRewards, {day = day, coins = day * 250})
            end
        end
        
        table.sort(DailyRewards, function(a, b) return a.day < b.day end)
        updateDailyRewardList()
        updateDailyUI()
    end)
end

local function updateDailyRewardList()
    for _, item in pairs(dailyRewardItems) do
        if item and item.Parent then
            item:Destroy()
        end
    end
    dailyRewardItems = {}
    
    local totalWidth = #DailyRewards * 70 + 10
    HorizontalScroll.CanvasSize = UDim2.new(0, totalWidth, 0, 0)
    
    for _, reward in ipairs(DailyRewards) do
        local item = Instance.new("Frame", HorizontalScroll)
        item.Size = UDim2.new(0, 60, 1, -10)
        item.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        Instance.new("UICorner", item).CornerRadius = UDim.new(0, 6)
        
        local isUnlocked = reward.day <= currentStreak
        local isNext = reward.day == currentStreak + 1
        
        local color = Color3.fromRGB(150, 150, 150)
        if isUnlocked then
            color = Color3.fromRGB(0, 200, 0)
        elseif isNext then
            color = Color3.fromRGB(255, 215, 0)
        else
            color = Color3.fromRGB(80, 80, 80)
        end
        item.BackgroundColor3 = color
        item.BackgroundTransparency = 0.3
        
        local dayLabel = Instance.new("TextLabel", item)
        dayLabel.Size = UDim2.new(1, 0, 0, 20)
        dayLabel.Position = UDim2.new(0, 0, 0, 2)
        dayLabel.BackgroundTransparency = 1
        dayLabel.Text = "Day " .. reward.day
        dayLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        dayLabel.Font = Enum.Font.GothamBold
        dayLabel.TextSize = 10
        
        local coinLabel = Instance.new("TextLabel", item)
        coinLabel.Size = UDim2.new(1, 0, 0, 20)
        coinLabel.Position = UDim2.new(0, 0, 0, 25)
        coinLabel.BackgroundTransparency = 1
        coinLabel.Text = formatCoins(reward.coins) .. "🪙"
        coinLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
        coinLabel.Font = Enum.Font.Gotham
        coinLabel.TextSize = 9
        
        local iconLabel = Instance.new("TextLabel", item)
        iconLabel.Size = UDim2.new(1, 0, 0, 18)
        iconLabel.Position = UDim2.new(0, 0, 0, 48)
        iconLabel.BackgroundTransparency = 1
        iconLabel.Text = isUnlocked and "✅" or (isNext and "👉" or "🔒")
        iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        iconLabel.Font = Enum.Font.Gotham
        iconLabel.TextSize = 12
        
        table.insert(dailyRewardItems, item)
    end
end

local function updateDailyUI()
    local today = getToday()
    local nextDay = currentStreak + 1
    
    if lastClaimDate ~= today and lastClaimDate ~= "" then
        local yesterday = os.date("*t", os.time() - 86400)
        local yesterdayStr = string.format("%d-%d-%d", yesterday.day, yesterday.month, yesterday.year)
        if lastClaimDate ~= yesterdayStr then
            currentStreak = 0
        end
    end
    
    local nextReward = nil
    for _, reward in ipairs(DailyRewards) do
        if reward.day == nextDay then
            nextReward = reward
            break
        end
    end
    
    if nextReward and nextDay <= 30 then
        DayLabel.Text = "📅 Day: " .. nextDay .. " / 30"
        RewardLabel.Text = "🎁 Reward: " .. formatCoins(nextReward.coins) .. " 🪙"
    elseif currentStreak >= 30 then
        DayLabel.Text = "🎉 ALL COMPLETED!"
        RewardLabel.Text = "🎁 Max reward achieved!"
    else
        DayLabel.Text = "📅 Day: " .. nextDay .. " / 30"
        RewardLabel.Text = "🎁 Reward: 0 🪙"
    end
    
    StreakLabel.Text = "🔥 Streak: " .. currentStreak .. " / 30 days"
    
    if lastClaimDate == today then
        ClaimBtn.Text = "✅ CLAIMED TODAY"
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        ClaimBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        StatusLabel.Text = "⏳ Come back at 00:00!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    elseif currentStreak >= 30 then
        ClaimBtn.Text = "🎉 ALL DONE!"
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        ClaimBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
        StatusLabel.Text = "🎊 You completed all 30 days!"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        ClaimBtn.Text = "🎁 CLAIM REWARD"
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
        ClaimBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        StatusLabel.Text = "✅ Ready to claim!"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    end
    
    CoinsDailyLabel.Text = "💸 Coins: " .. formatCoins(settings.Coins) .. " | X" .. settings.Multiplier
end

local function claimDailyReward()
    if isClaiming then return end
    
    local today = getToday()
    
    if lastClaimDate == today then
        showNoCoinsAlert("❌ You already claimed today's reward!\nCome back at 00:00!")
        return
    end
    
    if currentStreak >= 30 then
        showNoCoinsAlert("🎉 You completed all 30 days!\nGreat job!")
        return
    end
    
    local yesterday = os.date("*t", os.time() - 86400)
    local yesterdayStr = string.format("%d-%d-%d", yesterday.day, yesterday.month, yesterday.year)
    if lastClaimDate ~= "" and lastClaimDate ~= yesterdayStr then
        currentStreak = 0
        updateDailyRewardList()
    end
    
    local nextDay = currentStreak + 1
    local nextReward = nil
    for _, reward in ipairs(DailyRewards) do
        if reward.day == nextDay then
            nextReward = reward
            break
        end
    end
    
    if not nextReward then
        showNoCoinsAlert("❌ No reward available!")
        return
    end
    
    isClaiming = true
    ClaimBtn.Text = "🔄 CLAIMING..."
    ClaimBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    ClaimBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    
    lastClaimDate = today
    currentStreak = currentStreak + 1
    
    local gain = nextReward.coins * settings.Multiplier
    settings.Coins = settings.Coins + gain
    updateCoinsUI()
    saveVIPData()
    
    StatusLabel.Text = "🎉 +" .. gain .. " Coins!"
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "🎉 Daily Reward!",
            Text = "Day " .. nextDay .. ": +" .. gain .. " Coins! (X"..settings.Multiplier..")",
            Duration = 3,
        })
    end)
    
    task.wait(0.5)
    
    updateDailyRewardList()
    updateDailyUI()
    
    isClaiming = false
end

ClaimBtn.MouseButton1Click:Connect(claimDailyReward)

