-- CHỈNH SỬA: Dùng Heartbeat thay vì RenderStepped (ít lag hơn)
-- VÀ CHỈ CẬP NHẬT KHI CẦN THIẾT
rs.Heartbeat:Connect(function()
    for _, p in pairs(players:GetPlayers()) do
        if p ~= player then
            -- Kiểm tra thay đổi team
            updatePlayerTeamStatus(p)
            
            -- Chỉ cập nhật nếu có thay đổi settings
            if p.Character then
                if settings.HitboxAll then 
                    applyHitboxReal(p, false)
                elseif settings.HitboxTeam then
                    applyHitboxReal(p, true)
                else 
                    resetHitboxReal(p)
                end
                
                if settings.ESPAll then 
                    applyESP(p, false) 
                elseif settings.ESPTeam then
                    applyESP(p, true)
                else 
                    resetESP(p) 
                end
            end
        end
    end
end)

-- LẮNG NGHE SỰ KIỆN TEAM THAY ĐỔI NGAY LẬP TỨC
for _, p in pairs(players:GetPlayers()) do
    if p ~= player then
        p.CharacterAdded:Connect(function()
            wait(0.1) -- Chờ nhân vật load xong
            if settings.HitboxAll then
                applyHitboxReal(p, false)
            elseif settings.HitboxTeam then
                applyHitboxReal(p, true)
            end
            if settings.ESPAll then
                applyESP(p, false)
            elseif settings.ESPTeam then
                applyESP(p, true)
            end
        end)
    end
end

players.PlayerAdded:Connect(function(p)
    playerCache[p.UserId] = { team = p.Team }
    
    p.Changed:Connect(function(prop)
        if prop == "Team" then
            updatePlayerTeamStatus(p)
        end
    end)
    
    p.CharacterAdded:Connect(function()
        wait(0.1)
        if settings.HitboxAll then
            applyHitboxReal(p, false)
        elseif settings.HitboxTeam then
            applyHitboxReal(p, true)
        end
        if settings.ESPAll then
            applyESP(p, false)
        elseif settings.ESPTeam then
            applyESP(p, true)
        end
    end)
end)

players.PlayerRemoving:Connect(function(p)
