local function updateDailyUI()
    local today = getToday()
    local nextDay = currentStreak + 1
    
    if lastClaimDate ~= today and lastClaimDate ~= "" then
        local yesterday = os.date("*t", os.time() - 86400)
        local yesterdayStr = string.format("%d-%d-%d", yesterday.day, yesterday.month, yesterday.year)
        if lastClaimDate ~= yesterdayStr then currentStreak = 0 end
    end
    
    local nextReward = nil
    for _, reward in ipairs(DailyRewards) do
        if reward.day == nextDay then nextReward = reward break end
    end
    
    if nextReward and nextDay <= 30 then
        DayLabel.Text = "📅 Day: " .. nextDay .. " / 30"
        RewardLabel.Text = "🎁 Reward: " .. formatCoins(nextReward.coins) .. " 🪙"
    elseif currentStreak >= 30 then
        DayLabel.Text = "🎉 ALL COMPLETED!"
        RewardLabel.Text = "🎁 Max reward achieved!"
    else
        DayLabel.Text = "📅 Day: " .. nextDay .. " / 30"
        RewardLabel.Text = "🎁 Reward: 0 🪙"
    end
    
    StreakLabel.Text = "🔥 Streak: " .. currentStreak .. " / 30 days"
    
    if lastClaimDate == today then
        ClaimBtn.Text = "✅ CLAIMED TODAY"
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        ClaimBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        StatusLabel.Text = "⏳ Come back at 00:00!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    elseif currentStreak >= 30 then
        ClaimBtn.Text = "🎉 ALL DONE!"
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        ClaimBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
        StatusLabel.Text = "🎊 You completed all 30 days!"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        ClaimBtn.Text = "🎁 CLAIM REWARD"
        ClaimBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
        ClaimBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        StatusLabel.Text = "✅ Ready to claim!"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    end
    
    CoinsDailyLabel.Text = "💸 Coins: " .. formatCoins(settings.Coins) .. " | X" .. settings.Multiplier
end

local function claimDailyReward()
    if isClaiming then return end
    local today = getToday()
    if lastClaimDate == today then
        showNoCoinsAlert("❌ You already claimed today's reward!\nCome back at 00:00!")
        return
    end
    if currentStreak >= 30 then
        showNoCoinsAlert("🎉 You completed all 30 days!\nGreat job!")
        return
    end
    local yesterday = os.date("*t", os.time() - 86400)
    local yesterdayStr = string.format("%d-%d-%d", yesterday.day, yesterday.month, yesterday.year)
    if lastClaimDate ~= "" and lastClaimDate ~= yesterdayStr then
        currentStreak = 0
        updateDailyRewardList()
    end
    local nextDay = currentStreak + 1
    local nextReward = nil
    for _, reward in ipairs(DailyRewards) do
        if reward.day == nextDay then nextReward = reward break end
    end
    if not nextReward then showNoCoinsAlert("❌ No reward available!") return end
    
    isClaiming = true
    ClaimBtn.Text = "🔄 CLAIMING..."
    ClaimBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    ClaimBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    lastClaimDate = today
    currentStreak = currentStreak + 1
    local gain = nextReward.coins * settings.Multiplier
    settings.Coins = settings.Coins + gain
    updateCoinsUI()
    saveVIPData()
    StatusLabel.Text = "🎉 +" .. gain .. " Coins!"
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "🎉 Daily Reward!",
            Text = "Day " .. nextDay .. ": +" .. gain .. " Coins! (X"..settings.Multiplier..")",
            Duration = 3,
        })
    end)
    task.wait(0.5)
    updateDailyRewardList()
    updateDailyUI()
    isClaiming = false
end

