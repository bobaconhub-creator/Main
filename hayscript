local function getAccountFilePath(accountName)
    return "acc_" .. accountName:lower() .. "_coins.json"
end

local function loadAccountCoins(accountName)
    if not readfile or not isfile then return 0 end
    
    local filePath = getAccountFilePath(accountName)
    if isfile(filePath) then
        local success, data = pcall(function()
            local raw = readfile(filePath)
            return httpService:JSONDecode(decryptData(raw))
        end)
        if success and data and data.Coins then
            return data.Coins
        end
    end
    return 0
end

local function saveAccountCoins(accountName, coins)
    if not writefile then return false end
    
    local data = { Coins = coins }
    local success, encoded = pcall(function()
        local json = httpService:JSONEncode(data)
        return encryptData(json)
    end)
    
    if success then
        local filePath = getAccountFilePath(accountName)
        pcall(function()
            writefile(filePath, encoded)
        end)
        return true
    end
    return false
end

local function loadCurrentAccountCoins()
