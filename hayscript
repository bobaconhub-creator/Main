-- HỆ THỐNG MÃ HÓA VIPPRO
local function encryptData(data)
    local hex = ""
    for i = 1, #data do
        hex = hex .. string.format("%02X", string.byte(data, i) + 7) 
    end
    return "vippro_" .. hex
end

local function decryptData(data)
    if string.sub(data, 1, 7) == "vippro_" then
        local hex = string.sub(data, 8)
        local str = ""
        for i = 1, #hex, 2 do
            str = str .. string.char(tonumber(string.sub(hex, i, i+1), 16) - 7)
        end
        return str
    end
    return data 
end

-- Đọc/Ghi File lưu dữ liệu VIP và Coins địa phương
local function saveVIPData()
    if writefile then
        pcall(function()
            local vipEncoded = httpService:JSONEncode(settings.VIP_Status)
            writefile("hayhub_Config.json", encryptData(vipEncoded))
            
            local coinsData = {
                Coins = settings.Coins, 
                Diamonds = settings.Diamonds,
                Multiplier = settings.Multiplier,
                HasRedeemedNewbie = settings.HasRedeemedNewbie, 
                RedeemedCodes = settings.RedeemedCodes or {},
                AFK_Enabled = settings.AFK_Enabled,
                AFK_OfflineTime = settings.AFK_OfflineTime
            }
            local coinsEncoded = httpService:JSONEncode(coinsData)
            writefile("coinshayhub.json", encryptData(coinsEncoded))
        end)
    end
end

local function loadVIPData()
    if readfile and isfile then
        if isfile("hayhub_Config.json") then
            local success, data = pcall(function()
                local raw = readfile("hayhub_Config.json")
                return httpService:JSONDecode(decryptData(raw))
            end)
            if success and data then
                if data.IsUnlocked and data.KeyType == "Normal10" then
                    local timePassed = os.time() - data.LastSavedTime
                    data.TimeRemaining = math.max(0, data.TimeRemaining - timePassed)
                    if data.TimeRemaining <= 0 then
                        data.IsUnlocked = false
                        data.KeyType = ""
                    end
                end
                settings.VIP_Status = data
            end
        end
        if isfile("coinshayhub.json") then
            local success, data = pcall(function()
                local raw = readfile("coinshayhub.json")
                return httpService:JSONDecode(decryptData(raw))
            end)
            if success and data then
                if data.Coins then settings.Coins = data.Coins end
                if data.Diamonds then settings.Diamonds = data.Diamonds end
                if data.Multiplier then settings.Multiplier = data.Multiplier end
                if data.HasRedeemedNewbie ~= nil then settings.HasRedeemedNewbie = data.HasRedeemedNewbie end
                if data.RedeemedCodes then settings.RedeemedCodes = data.RedeemedCodes end
                if data.AFK_Enabled ~= nil then settings.AFK_Enabled = data.AFK_Enabled end
                if data.AFK_OfflineTime then settings.AFK_OfflineTime = data.AFK_OfflineTime end
            end
        end
    end
end
