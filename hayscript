local function startRandomClickChallenge(totalWindows, finalKeyType, onComplete, customTime)
    KeySelectFrame.Visible = false
    OptionFrame.Visible = false
    MainFrame.Visible = false 
    local count = 0
    local maxTime = customTime or 10
    
    local function spawnChallengeWindow()
        count = count + 1
        if count <= 0 then MainFrame.Visible = true return end
        if count > totalWindows then onComplete() return end
        
        local isDelayWindow = false
        if finalKeyType == "Normal10" and count >= 51 then isDelayWindow = true
        elseif finalKeyType == "Permanent" and count >= 196 then isDelayWindow = true end
        
        local challengeFrame = Instance.new("Frame", ScreenGui)
        challengeFrame.Size = UDim2.new(0, 360, 0, 260)
        challengeFrame.Position = UDim2.new(0.5, math.random(-40, 40) - 180, 0.5, math.random(-30, 30) - 130)
        challengeFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Instance.new("UICorner", challengeFrame).CornerRadius = UDim.new(0, 10)
        
        local title = Instance.new("TextLabel", challengeFrame)
        title.Size = UDim2.new(1, 0, 0, 35)
        title.Text = "Thử thách quảng cáo ("..count.."/"..totalWindows..")"
        title.TextColor3 = Color3.fromRGB(255, 255, 255)
        title.Font = Enum.Font.GothamBold
        title.TextSize = 11
        
        local timerLabel = Instance.new("TextLabel", challengeFrame)
        timerLabel.Size = UDim2.new(1, 0, 0, 20)
        timerLabel.Position = UDim2.new(0, 0, 0, 30)
        timerLabel.Text = "Thời gian còn lại: " .. maxTime .. "s"
        timerLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        timerLabel.Font = Enum.Font.GothamBold
        timerLabel.TextSize = 12
        timerLabel.BackgroundTransparency = 1

        local buttonContainer = Instance.new("Frame", challengeFrame)
        buttonContainer.Size = UDim2.new(1, -20, 1, -65)
        buttonContainer.Position = UDim2.new(0, 10, 0, 55)
        buttonContainer.BackgroundTransparency = 1

        local timeOut = false
        local challengeActive = true

        if isDelayWindow then
            timerLabel.Visible = false
            local delayBtn = Instance.new("TextButton", buttonContainer)
            delayBtn.Size = UDim2.new(1, 0, 0, 50)
            delayBtn.Position = UDim2.new(0, 0, 0, 60)
            delayBtn.Font = Enum.Font.GothamBold
            delayBtn.TextSize = 13
            delayBtn.BackgroundColor3 = Color3.fromRGB(220, 120, 0)
            delayBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            delayBtn.Text = "BẤM VÀO ĐÂY ĐỂ CHỜ QUẢNG CÁO"
            Instance.new("UICorner", delayBtn).CornerRadius = UDim.new(0, 8)
            
            local clicked = false
            delayBtn.MouseButton1Click:Connect(function()
                if clicked then return end
                clicked = true
                delayBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                local timeLeft = 120
                task.spawn(function()
                    while timeLeft > 0 do
                        delayBtn.Text = "Vui lòng chờ: " .. timeLeft .. "s"
                        task.wait(1)
                        timeLeft = timeLeft - 1
                    end
                    challengeFrame:Destroy()
                    spawnChallengeWindow()
                end)
            end)
        else
            local grid = Instance.new("UIGridLayout", buttonContainer)
            grid.CellSize = UDim2.new(0, 80, 0, 35)
            grid.HorizontalAlignment = Enum.HorizontalAlignment.Center
            grid.VerticalAlignment = Enum.VerticalAlignment.Center
            grid.SortOrder = Enum.SortOrder.LayoutOrder
            
            local totalButtons = 20
            local correctIndex = math.random(1, totalButtons)
            
            task.spawn(function()
                local countdown = maxTime
                while countdown > 0 and challengeActive do
                    timerLabel.Text = "Thời gian còn lại: " .. countdown .. "s"
                    task.wait(1)
                    countdown = countdown - 1
                end
                if challengeActive then
                    timeOut = true
                    challengeActive = false
                    challengeFrame:Destroy()
                    count = count - 2 
                    spawnChallengeWindow()
                end
            end)

            for i = 1, totalButtons do
                local btn = Instance.new("TextButton", buttonContainer)
                btn.Font = Enum.Font.GothamBold
                btn.TextSize = 9
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
                
                if i == correctIndex then
                    btn.Text = "BẤM VÀO ĐÂY"
                    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
                    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    btn.MouseButton1Click:Connect(function() 
                        if not challengeActive then return end
                        challengeActive = false
                        challengeFrame:Destroy() 
                        spawnChallengeWindow() 
                    end)
                else
                    btn.Text = "CLICK HERE"
                    btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
                    btn.MouseButton1Click:Connect(function() 
                        if not challengeActive then return end
                        challengeActive = false
                        challengeFrame:Destroy() 
                        count = count - 2 
                        spawnChallengeWindow() 
                    end)
                end
            end
        end
    end
    spawnChallengeWindow()
end

