local function buyVIP(coins)
    if not coins or coins <= 0 then
        showNoCoinsAlert("❌ Vui lòng nhập số Coins hợp lệ!")
        return
    end
    local hours = coins / 100
    hours = math.max(0.5, math.min(720, hours))
    local timeSeconds = hours * 3600
    if settings.Coins >= coins then
        settings.Coins = settings.Coins - coins
        if settings.VIP_Status.IsUnlocked then
            settings.VIP_Status.TimeRemaining = settings.VIP_Status.TimeRemaining + timeSeconds
        else
            settings.VIP_Status.IsUnlocked = true
            settings.VIP_Status.KeyType = "Normal10"
            settings.VIP_Status.TimeRemaining = timeSeconds
        end
        settings.VIP_Status.LastSavedTime = os.time()
        updateCoinsUI()
        saveVIPData()
        updateBuyKeyUI()
        showNoCoinsAlert("✅ Mua VIP thành công!\n⏰ +" .. formatHPS(timeSeconds) .. " VIP\n💸 -" .. formatCoins(coins) .. " Coins")
        CoinInput.Text = ""
        ResultLabel.Text = "✅ Đã mua thành công! Bạn nhận được " .. formatHPS(timeSeconds) .. " VIP"
        ResultLabel.TextColor3 = Color3.fromRGB(0, 150, 0)
    else
        showNoCoinsAlert("❌ Bạn không đủ tiền!\nCần " .. formatCoins(coins) .. " Coins\nBạn có " .. formatCoins(settings.Coins) .. " Coins")
    end
end

