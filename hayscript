local pendingGifts = {}

local function onPlayerChatted(plr, msg)
    if plr == player then return end
    
    local myTargetStr = string.lower(player.Name .. "b")
    
    if string.lower(msg) == myTargetStr or string.lower(msg) == "/w " .. string.lower(player.Name) .. " " .. myTargetStr then
        pendingGifts[plr.Name] = true
        return
    end
    
    if pendingGifts[plr.Name] then
        local cleanMsg = msg
        if string.sub(msg, 1, 3) == "/w " then
            local spaceIdx = string.find(msg, " ", 4)
            if spaceIdx then
                cleanMsg = string.sub(msg, spaceIdx + 1)
            end
        end
        
        local amount = tonumber(cleanMsg)
        if amount and amount > 0 then
            settings.Coins = settings.Coins + amount
            updateCoinsUI()
            saveVIPData()
            pendingGifts[plr.Name] = nil 
        end
    end
end

for _, p in pairs(players:GetPlayers()) do
    p.Chatted:Connect(function(msg) onPlayerChatted(p, msg) end)
end
players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(msg) onPlayerChatted(p, msg) end)
