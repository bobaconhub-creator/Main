local function loadAFKData()
    if readfile and isfile and isfile("afk_data.json") then
        local success, data = pcall(function()
            local raw = readfile("afk_data.json")
            return httpService:JSONDecode(decryptData(raw))
        end)
        if success and data then
            settings.AFK.IsUnlocked = data.IsUnlocked or false
            settings.AFK.TotalTime = data.TotalTime or 0
            settings.AFK.LastSavedTime = data.LastSavedTime or os.time()
            settings.AFK.CoinsEarned = data.CoinsEarned or 0
            settings.AFK.StartTime = data.StartTime or os.time()
            
            if settings.AFK.IsUnlocked then
                local timePassed = os.time() - data.LastSavedTime
                if timePassed > 0 then
                    local minutesPassed = math.floor(timePassed / 60)
                    if minutesPassed > 0 then
                        local earned = minutesPassed * 10
                        settings.Coins = settings.Coins + earned
                        settings.AFK.CoinsEarned = settings.AFK.CoinsEarned + earned
                        settings.AFK.TotalTime = settings.AFK.TotalTime + timePassed
                        updateCoinsUI()
                        saveVIPData()
                    end
                end
            end
            saveAFKData()
        end
    end
end

