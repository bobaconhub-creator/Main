if not getgenv().AntiKickLoaded then
    getgenv().AntiKickLoaded = true
    
    setreadonly(mt, false)
    local old_namecall = mt.__namecall
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        
        -- Chặn gọi hàm Kick trực tiếp lên nhân vật
        if self == plr and (method == "Kick" or method:lower():find("kick") or method:lower():find("ban") or method:lower():find("detected")) then
