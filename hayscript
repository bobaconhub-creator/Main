        streakLabel.Text = "Tiến độ: " .. streak .. "/4"
        
        local options = {currentAnswer, currentAnswer + math.random(1,3), currentAnswer - math.random(1,3)}
        -- Shuffle array
        for i = #options, 2, -1 do
            local j = math.random(i)
            options[i], options[j] = options[j], options[i]
        end
        b1.Text = tostring(options[1])
        b2.Text = tostring(options[2])
        b3.Text = tostring(options[3])
    end
    
    local function handleAnswer(selected)
        if tonumber(selected) == currentAnswer then
            streak = streak + 1
