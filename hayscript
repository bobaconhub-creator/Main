local function loadDailyRewards()
    pcall(function()
        local res = game:HttpGet("https://raw.githubusercontent.com/vukk2k12-hub/vukk/refs/heads/main/dayli")
        DailyRewards = {}
        for line in res:gmatch("[^\r\n]+") do
            local split = string.split(line, ":")
            if #split == 2 then
                local coins = tonumber(split[1]) or 0
                local day = tonumber(split[2]) or 0
                if day >= 1 and day <= 30 then
                    table.insert(DailyRewards, {day = day, coins = coins})
                end
            end
        end
        if #DailyRewards == 0 then
            for day = 1, 30 do
                table.insert(DailyRewards, {day = day, coins = day * 250})
            end
        end
        table.sort(DailyRewards, function(a, b) return a.day < b.day end)
        updateDailyRewardList()
        updateDailyUI()
    end)
end

