-- Hàm rút gọn tiền (K, M, B, T, Qa, Qi...)
local function formatCoins(n)
    local num = tonumber(n)
    if not num then return "0" end
    if num < 1000 then return tostring(num) end

    local suffixes = {
        "K", "M", "B", "T", "Qa", "Qi", "Sx", "Sp", "Oc", "No", "Dc", "Ud", "Dd", "Td"
    }
    
    local suffixIndex = 0
    while num >= 1000 and suffixIndex < #suffixes do
        num = num / 1000
        suffixIndex = suffixIndex + 1
    end

    return string.format("%.1f", num):gsub("%.0$", "") .. suffixes[suffixIndex]
end

local function updateCoinsUI()
    CoinsLabel.Text = "💸 Coins: " .. formatCoins(settings.Coins)
end
