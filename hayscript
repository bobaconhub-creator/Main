-- Hàm kiểm tra thời gian code
local function isCodeTimeValid(timeString)
    if not timeString or timeString == "" or timeString == "0" then return true end
    if timeString == "true" or timeString == "false" then return true end
    
    local parts = {}
    for part in string.gmatch(timeString, "[^,]+") do
        table.insert(parts, part)
    end
    
    local now = os.date("*t")
    local currentMinutes = now.hour * 60 + now.min
    local currentDay = now.day
    local currentMonth = now.month
    local currentYear = now.year
    
    local isHourValid = true
    local isDateValid = true
    
    for _, part in ipairs(parts) do
        local hourMatch = string.match(part, "^(%d+)%.(%d+)-(%d+)%.(%d+)$")
        if hourMatch then
            local startH, startM, endH, endM = tonumber(hourMatch), tonumber(hourMatch), tonumber(hourMatch), tonumber(hourMatch)
            local startMinutes = startH * 60 + startM
            local endMinutes = endH * 60 + endM
            
            if startMinutes <= endMinutes then
                isHourValid = (currentMinutes >= startMinutes and currentMinutes <= endMinutes)
            else
                isHourValid = (currentMinutes >= startMinutes or currentMinutes <= endMinutes)
            end
        end
        
        local dateMatch = string.match(part, "^(%d+)/(%d+)$")
        if dateMatch then
            local day, month = tonumber(dateMatch), tonumber(dateMatch)
            isDateValid = (day == currentDay and month == currentMonth)
        end
        
        local dateFullMatch = string.match(part, "^(%d+)/(%d+)/(%d+)$")
        if dateFullMatch then
            local day, month, year = tonumber(dateFullMatch), tonumber(dateFullMatch), tonumber(dateFullMatch)
            isDateValid = (day == currentDay and month == currentMonth and year == currentYear)
        end
        
        local dateRangeMatch = string.match(part, "^(%d+)/(%d+)-(%d+)/(%d+)$")
        if dateRangeMatch then
            local startD, startM, endD, endM = tonumber(dateRangeMatch), tonumber(dateRangeMatch), tonumber(dateRangeMatch), tonumber(dateRangeMatch)
            
            if startM < endM or (startM == endM and startD <= endD) then
                if currentMonth > startM and currentMonth < endM then 
                    isDateValid = true
                elseif currentMonth == startM and currentDay >= startD then 
                    isDateValid = true
                elseif currentMonth == endM and currentDay <= endD then 
                    isDateValid = true
                else
                    isDateValid = false
                end
            else
                if currentMonth > startM or currentMonth < endM then 
                    isDateValid = true
                elseif currentMonth == startM and currentDay >= startD then 
                    isDateValid = true
                elseif currentMonth == endM and currentDay <= endD then 
                    isDateValid = true
                else
                    isDateValid = false
                end
            end
        end
        
        local dateRangeFullMatch = string.match(part, "^(%d+)/(%d+)/(%d+)-(%d+)/(%d+)/(%d+)$")
        if dateRangeFullMatch then
            local startD, startM, startY, endD, endM, endY = tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch)
            local startDate = os.time({day=startD, month=startM, year=startY})
            local endDate = os.time({day=endD, month=endM, year=endY})
            local nowTime = os.time()
            
            isDateValid = (nowTime >= startDate and nowTime <= endDate)
        end
    end
    
    return isHourValid and isDateValid
end

-- Hàm lấy text hiển thị thời gian
local function getTimeDisplayText(timeString)
    if not timeString or timeString == "" or timeString == "0" then return "🟢 Bất kì lúc nào" end
    if timeString == "true" or timeString == "false" then return "🟢 Bất kì lúc nào" end
    
    local parts = {}
    for part in string.gmatch(timeString, "[^,]+") do
        table.insert(parts, part)
    end
    
    local displayTexts = {}
    
    for _, part in ipairs(parts) do
        local hourMatch = string.match(part, "^(%d+)%.(%d+)-(%d+)%.(%d+)$")
        if hourMatch then
            local startH, startM, endH, endM = tonumber(hourMatch), tonumber(hourMatch), tonumber(hourMatch), tonumber(hourMatch)
            table.insert(displayTexts, "⏰ " .. string.format("%02d.%02d", startH, startM) .. " - " .. string.format("%02d.%02d", endH, endM))
        end
        
        local dateMatch = string.match(part, "^(%d+)/(%d+)$")
        if dateMatch then
            local day, month = tonumber(dateMatch), tonumber(dateMatch)
            table.insert(displayTexts, "📅 " .. string.format("%02d/%02d", day, month))
        end
        
        local dateFullMatch = string.match(part, "^(%d+)/(%d+)/(%d+)$")
        if dateFullMatch then
            local day, month, year = tonumber(dateFullMatch), tonumber(dateFullMatch), tonumber(dateFullMatch)
            table.insert(displayTexts, "📅 " .. string.format("%02d/%02d/%d", day, month, year))
        end
        
        local dateRangeMatch = string.match(part, "^(%d+)/(%d+)-(%d+)/(%d+)$")
        if dateRangeMatch then
            local startD, startM, endD, endM = tonumber(dateRangeMatch), tonumber(dateRangeMatch), tonumber(dateRangeMatch), tonumber(dateRangeMatch)
            table.insert(displayTexts, "📅 " .. string.format("%02d/%02d", startD, startM) .. " - " .. string.format("%02d/%02d", endD, endM))
        end
        
        local dateRangeFullMatch = string.match(part, "^(%d+)/(%d+)/(%d+)-(%d+)/(%d+)/(%d+)$")
        if dateRangeFullMatch then
            local startD, startM, startY, endD, endM, endY = tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch), tonumber(dateRangeFullMatch)
            table.insert(displayTexts, "📅 " .. string.format("%02d/%02d/%d", startD, startM, startY) .. " - " .. string.format("%02d/%02d/%d", endD, endM, endY))
        end
    end
    
    if #displayTexts == 0 then return "🟢 Bất kì lúc nào" end
    
    return table.concat(displayTexts, " | ")
end

