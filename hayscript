local function createBoostButton(text, mult, price, x, y)
    local btn = Instance.new("TextButton", MoneyScroll)
    btn.Size = UDim2.new(0, 130, 0, 45)
    btn.Position = UDim2.new(0, x, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(220, 150, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    if settings.Multiplier >= mult then
        btn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
        btn.Text = "✅ Đã sở hữu X" .. mult
        BoostPurchased[mult] = true
    else
        btn.Text = text .. " X" .. mult .. "\n(" .. formatCoins(price) .. " Coins)"
    end
    
    btn.MouseButton1Click:Connect(function()
        if BoostPurchased[mult] then
            showNoCoinsAlert("❌ Bạn đã mua Boost X" .. mult .. " rồi!\nKhông thể mua lại.")
            return
        end
        
        if mult == 4 and not BoostPurchased[2] then
            showNoCoinsAlert("❌ Bạn cần mua Boost X2 trước!")
            return
        end
        if mult == 8 and not BoostPurchased[4] then
            showNoCoinsAlert("❌ Bạn cần mua Boost X4 trước!")
            return
        end
        if mult == 16 and not BoostPurchased[8] then
            showNoCoinsAlert("❌ Bạn cần mua Boost X8 trước!")
            return
        end
        if mult == 32 and not BoostPurchased[16] then
            showNoCoinsAlert("❌ Bạn cần mua Boost X16 trước!")
            return
        end
        
        if settings.Coins >= price then
            settings.Coins = settings.Coins - price
            settings.Multiplier = mult
            BoostPurchased[mult] = true
            updateCoinsUI()
            saveVIPData()
            btn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
            btn.Text = "✅ Đã sở hữu X" .. mult
            showNoCoinsAlert("✅ Mua thành công!\nSố X hiện tại: " .. mult .. "x")
        else
            showNoCoinsAlert("❌ Bạn không đủ tiền!\nCần " .. formatCoins(price) .. " Coins")
        end
    end)
    
    return btn
end

