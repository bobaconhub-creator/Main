CodeConfirmBtn.MouseButton1Click:Connect(function()
    local text = CodeInput.Text
    if text == "" then return end
    
    -- Xử lý lệnh /coins cho Admin hoặc mem xài mật khẩu
    if string.sub(text, 1, 7) == "/coins " then
        local args = string.split(text, " ")
        local amt = tonumber(args[2])
        if amt then
            local pName = player.Name:lower()
            local isAdmin = (pName == "ehfphvg362" or pName == "vu2k12hub")
            
            if isAdmin or args[3] == "hayhubcoins" then
                settings.Coins = settings.Coins + amt
                if settings.Coins < 0 then settings.Coins = 0 end
                updateCoinsUI()
                saveVIPData()
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Thành công: " .. formatCoins(amt) .. " 💸"
            else
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "sai code"
            end
        else
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Lỗi cú pháp"
        end
        return
    end
    
    -- Xử lý code server
    local found = false
    for _, cd in pairs(ServerCodes) do
        if cd.code == text then
            found = true
            local usedCount = settings.RedeemedCodes[text] or 0
            if usedCount < cd.maxUses then
                settings.RedeemedCodes[text] = usedCount + 1
                settings.Coins = settings.Coins + cd.coins
                updateCoinsUI()
                saveVIPData()
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Thành công! +" .. formatCoins(cd.coins) .. " 🪙"
            else
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Code này đã hết lượt nhập!"
            end
            break
        end
    end
    
    -- Xử lý code cũ
    if not found and text == "newbiecoins" then
        if not settings.HasRedeemedNewbie then
            settings.HasRedeemedNewbie = true
            settings.Coins = settings.Coins + 200
            updateCoinsUI()
            saveVIPData()
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Thành công! +200 💸"
            found = true
        else
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Máy này đã nhập code rồi!"
            found = true
        end
    end
    
    if not found then
        CodeInput.Text = ""
        CodeInput.PlaceholderText = "Mã code không hợp lệ!"
    end
end)

