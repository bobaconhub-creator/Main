RunService.RenderStepped:Connect(function()

    for _,plr in pairs(Players:GetPlayers()) do

        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then

            local enemy = plr.Team ~= player.Team

            --------------------------------------------------
            -- HITBOX (CONTINUOUS UPDATE)

            if settings.HitboxAll or (settings.HitboxTeam and enemy) then
                applyHitbox(plr)
            else
                resetHitbox(plr)
            end

            --------------------------------------------------
            -- ESP (CONTINUOUS UPDATE)

            if settings.ESPAll or (settings.ESPTeam and enemy) then
                if not getESP(plr) and plr.Character then
                    createESP(plr,enemy)
                end
            else
                removeESP(plr)
            end
        end
    end
end)

