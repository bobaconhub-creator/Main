local function makeRandomString(length)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local str = ""
    for i = 1, length do
        local r = math.random(1, #chars)
        str = str .. string.sub(chars, r, r)
    end
    return str
end

-- CƠ CHẾ QUẢNG CÁO MỚI (Hỗ trợ 9 nút cho các bảng thường)
local function startRandomClickChallenge(totalWindows, finalKeyType, onComplete)
    KeySelectFrame.Visible = false
    MainFrame.Visible = false 
    
    local count = 0
    local function spawnChallengeWindow()
        count = count + 1
        if count > totalWindows then
            onComplete()
            return
        end
        
        -- Xác định xem bảng hiện tại có phải là bảng bắt buộc chờ 2 phút hay không
        local isDelayWindow = false
        if finalKeyType == "Normal10" and count >= 21 then
            isDelayWindow = true -- 2 cái cuối của mốc 22 bảng (Bảng 21, 22)
        elseif finalKeyType == "Permanent" and count >= 46 then
            isDelayWindow = true -- 5 cái cuối của mốc 50 bảng (Bảng 46 -> 50)
        end
        
        local challengeFrame = Instance.new("Frame", ScreenGui)
        -- Tăng kích thước bảng quảng cáo lên một chút (280x200) để vừa vặn 9 nút
        challengeFrame.Size = UDim2.new(0, 280, 0, 200)
        challengeFrame.Position = UDim2.new(0.5, math.random(-60, 60) - 140, 0.5, math.random(-40, 40) - 100)
        challengeFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Instance.new("UICorner", challengeFrame).CornerRadius = UDim.new(0, 10)
        
        local title = Instance.new("TextLabel", challengeFrame)
        title.Size = UDim2.new(1, 0, 0, 35)
        title.Text = "Thử thách quảng cáo VIP ("..count.."/"..totalWindows..")"
        title.TextColor3 = Color3.fromRGB(255, 255, 255)
        title.Font = Enum.Font.GothamBold
        title.TextSize = 11
        
        local buttonContainer = Instance.new("Frame", challengeFrame)
        buttonContainer.Size = UDim2.new(1, -20, 1, -45)
        buttonContainer.Position = UDim2.new(0, 10, 0, 40)
        buttonContainer.BackgroundTransparency = 1

        -- Nếu là bảng chờ 2 phút: Chỉ hiện 1 nút kích hoạt đếm ngược
        if isDelayWindow then
            local delayBtn = Instance.new("TextButton", buttonContainer)
            delayBtn.Size = UDim2.new(1, 0, 0, 50)
            delayBtn.Position = UDim2.new(0, 0, 0, 45)
            delayBtn.Font = Enum.Font.GothamBold
            delayBtn.TextSize = 13
            delayBtn.BackgroundColor3 = Color3.fromRGB(220, 120, 0)
            delayBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            delayBtn.Text = "BẤM VÀO ĐÂY ĐỂ CHỜ QUẢNG CÁO"
            Instance.new("UICorner", delayBtn).CornerRadius = UDim.new(0, 8)
            
            local clicked = false
            delayBtn.MouseButton1Click:Connect(function()
                if clicked then return end
                clicked = true
                delayBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                
                local timeLeft = 120
                task.spawn(function()
                    while timeLeft > 0 do
                        delayBtn.Text = "Vui lòng chờ: " .. timeLeft .. "s"
                        task.wait(1)
                        timeLeft = timeLeft - 1
                    end
                    challengeFrame:Destroy()
                    spawnChallengeWindow()
                end)
            end)
        else
            -- UPDATE: Thay đổi cơ chế từ 4 nút thành 9 nút (Lưới 3x3)
            local grid = Instance.new("UIGridLayout", buttonContainer)
            grid.CellSize = UDim2.new(0, 82, 0, 42) -- Căn chỉnh size nút nhỏ lại vừa khung
            grid.HorizontalAlignment = Enum.HorizontalAlignment.Center
            grid.VerticalAlignment = Enum.VerticalAlignment.Center
            grid.SortOrder = Enum.SortOrder.LayoutOrder
            
            local correctIndex = math.random(1, 9)
            for i = 1, 9 do
                local btn = Instance.new("TextButton", buttonContainer)
                btn.Font = Enum.Font.GothamBold
                btn.TextSize = 10
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
                
                if i == correctIndex then
                    btn.Text = "BẤM VÀO ĐÂY"
                    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
                    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    btn.MouseButton1Click:Connect(function()
                        challengeFrame:Destroy()
                        spawnChallengeWindow()
                    end)
                else
                    btn.Text = "CLICK HERE"
                    btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
                    btn.MouseButton1Click:Connect(function()
                        challengeFrame:Destroy()
                        count = math.max(0, count - 1) -- phạt lùi lại 1 bảng nếu bấm nút sai
                        spawnChallengeWindow()
                    end)
                end
            end
        end
    end
    spawnChallengeWindow()
end

