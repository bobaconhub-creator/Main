    local streakLabel = Instance.new("TextLabel", mathFrame)
    streakLabel.Size = UDim2.new(1, 0, 0, 20)
    streakLabel.Position = UDim2.new(0, 0, 0, 45)
    streakLabel.Font = Enum.Font.GothamBold
    streakLabel.TextSize = 12
    streakLabel.TextColor3 = Color3.fromRGB(255,255,0)
    streakLabel.BackgroundTransparency = 1
    streakLabel.Text = "Tiến độ: 0/4"
    
    local b1 = Instance.new("TextButton", mathFrame)
    b1.Size = UDim2.new(0, 70, 0, 40)
    b1.Position = UDim2.new(0, 15, 0, 80)
    b1.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
