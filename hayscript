local function applyHitboxReal(p, teamCheck)
    if p == player or not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then return end
    if settings.HitboxBlacklist[p.Name] then return end 
    if teamCheck and p.Team == player.Team then return end

    local hrp = p.Character.HumanoidRootPart
    if hrp.Size.X ~= settings.HitboxSize then 
        hrp.Size = Vector3.new(settings.HitboxSize, settings.HitboxSize, settings.HitboxSize)
        hrp.Transparency = settings.HitboxTransparency
        hrp.Material = Enum.Material.Neon
        hrp.Color = Color3.fromRGB(255,255,255)
    end
end

local function resetHitboxReal(p)
    if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = p.Character.HumanoidRootPart
    if hrp.Size.X ~= 2 then hrp.Size = Vector3.new(2,2,1) hrp.Transparency = 1 end
end

local function getHealthColor(hp)
    if hp >= 80 then return Color3.fromRGB(0, 255, 0)
    elseif hp > 30 then return Color3.fromRGB(255, 255, 0)
    else return Color3.fromRGB(255, 0, 0) end
end

local function createHealthBar(p)
    if p == player or not p.Character or p.Character:FindFirstChild("BaconHealthBar") then return end
    if settings.ESPBlacklist[p.Name] then return end 
    local humanoid = p.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Name = "BaconHealthBar"
    billboardGui.Size = UDim2.new(8, 0, 1, 0)
    billboardGui.StudsOffset = Vector3.new(0, 5, 0)
    billboardGui.MaxDistance = math.huge
    billboardGui.Adornee = p.Character:FindFirstChild("HumanoidRootPart")
    billboardGui.Parent = p.Character
    
    local container = Instance.new("Frame", billboardGui)
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 0.3
    container.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)
    
    local healthBar = Instance.new("Frame", container)
    healthBar.Name = "HealthBar"
    healthBar.Size = UDim2.new(1, -4, 1, -4)
    healthBar.Position = UDim2.new(0, 2, 0, 2)
    healthBar.BackgroundColor3 = getHealthColor(humanoid.Health)
    Instance.new("UICorner", healthBar).CornerRadius = UDim.new(0, 4)
    
    local function updateHealth(newHealth)
        local maxHealth = humanoid.MaxHealth
        local ratio = math.max(0, math.min(1, newHealth / maxHealth))
        healthBar.Size = UDim2.new(ratio, -4, 1, -4)
        healthBar.BackgroundColor3 = getHealthColor(newHealth)
    end
    
    updateHealth(humanoid.Health)
    humanoid.HealthChanged:Connect(updateHealth)
    humanoid.Died:Connect(function() if billboardGui.Parent then billboardGui:Destroy() end end)
end

local function removeHealthBar(p)
    if p.Character and p.Character:FindFirstChild("BaconHealthBar") then p.Character.BaconHealthBar:Destroy() end
end

local function applyESP(p, teamCheck)
    if p == player or not p.Character then return end
    if settings.ESPBlacklist[p.Name] then return end 
    if teamCheck and p.Team == player.Team then return end
    
    if not p.Character:FindFirstChild("BaconESP") then
        local hl = Instance.new("Highlight")
        hl.Name = "BaconESP"
        hl.FillTransparency = 1
        hl.OutlineTransparency = 0
        hl.OutlineColor = Color3.fromRGB(255,255,255)
        hl.Adornee = p.Character
        hl.Parent = p.Character
    end
    if settings.HealthDisplay then createHealthBar(p) end
end

local function resetESP(p)
    if not p.Character then return end
    if p.Character:FindFirstChild("BaconESP") then p.Character.BaconESP:Destroy() end
    removeHealthBar(p)
end

local function refreshPlayerVisuals(p)
    if not p.Character or p == player then return end
    
    if settings.HitboxBlacklist[p.Name] then 
        resetHitboxReal(p) 
    else
        if settings.HitboxAll then applyHitboxReal(p, false)
        elseif settings.HitboxTeam then applyHitboxReal(p, true)
        else resetHitboxReal(p) end
    end
    
    if settings.ESPBlacklist[p.Name] then 
        resetESP(p) 
    else
        if settings.ESPAll then applyESP(p, false) 
        elseif settings.ESPTeam then applyESP(p, true)
        else resetESP(p) end
    end
end

local function updatePlayerTeamStatus(p)
    if not playerCache[p.UserId] then playerCache[p.UserId] = { team = p.Team } end
    local oldTeam = playerCache[p.UserId].team
    local newTeam = p.Team
    if oldTeam ~= newTeam then
        playerCache[p.UserId].team = newTeam
        if p.Character then resetESP(p) resetHitboxReal(p) end
        refreshPlayerVisuals(p)
    end
end

