            showKickBlocked()
            return
        end
        
        -- Chặn Disconnect
        if method == "Disconnect" and self == plr then
            showKickBlocked()
            return
        end
        
        return old_namecall(self, ...)
    end)
    
    -- Hook trực tiếp hàm Kick nếu Executor hỗ trợ
    if hookfunction then
        hookfunction(plr.Kick, function() showKickBlocked() end)
    end
    
    -- Anti AFK (Chống văng game khi treo máy 20 phút)
    task.spawn(function()
        while task.wait(0.15) do
            pcall(function()
                for _, c in ipairs(getconnections(plr.Idled)) do
                    c:Disable()
                end
            end)
        end
    end)
    
    setreadonly(mt, true)
end
