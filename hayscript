-- Hàm cập nhật Event HUD
local function updateEventHUD()
    local hasActiveEvent = false
    local eventName = ""
    local eventReward = ""
    local endTime = nil
    
    for _, event in ipairs(EventData) do
        if isEventTimeValid(event.time) then
            hasActiveEvent = true
            eventName = event.name
            eventReward = event.reward
            local timeInfo = parseEventTime(event.time)
            if timeInfo and timeInfo.endTime then endTime = timeInfo.endTime end
            break
        end
    end
    
    if hasActiveEvent then
        EventPopup.Visible = true
        EventHUDName.Text = "📌 " .. string.upper(eventName)
        EventHUDReward.Text = "🎁 " .. eventReward
        
        if eventName:lower() == "chat" then
            EventHUDDesc.Text = "💬 Nhân đôi chat trong thời gian này!"
            EventHUDDesc.TextColor3 = Color3.fromRGB(255, 215, 0)
        elseif eventName:lower() == "hieuung" then
            EventHUDDesc.Text = "⚡ Boost X2 tất cả phần thưởng!"
            EventHUDDesc.TextColor3 = Color3.fromRGB(0, 255, 255)
            BoostHUD.Visible = true
            BoostTextHUD.Text = "X2 (Event)"
            BoostIcon.TextColor3 = Color3.fromRGB(0, 255, 100)
            BoostTextHUD.TextColor3 = Color3.fromRGB(0, 255, 100)
        else
            EventHUDDesc.Text = "🎯 Sự kiện đặc biệt đang diễn ra!"
        end
        
        if endTime then
            local remaining = endTime - os.time()
            if remaining > 0 then
                EventHUDTime.Text = "⏰ Còn: " .. formatCountdown(remaining)
                EventHUDTime.TextColor3 = Color3.fromRGB(0, 255, 0)
            else
                EventHUDTime.Text = "⏰ Đã kết thúc"
                EventHUDTime.TextColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
        
        EventHUDClaimBtn.Visible = true
    else
        EventPopup.Visible = false
        if settings.Multiplier <= 1 then BoostHUD.Visible = false end
    end
    
    if settings.Multiplier > 1 then
        BoostHUD.Visible = true
        if not hasActiveEvent or eventName:lower() ~= "hieuung" then
            BoostTextHUD.Text = "X" .. settings.Multiplier
            BoostIcon.TextColor3 = Color3.fromRGB(255, 215, 0)
            BoostTextHUD.TextColor3 = Color3.fromRGB(255, 215, 0)
        end
    end
end

EventHUDClaimBtn.MouseButton1Click:Connect(function()
    for _, event in ipairs(EventData) do
        if isEventTimeValid(event.time) then
            local today = getToday()
            local claimKey = event.name .. "_" .. today
            if lastEventClaim[claimKey] then
                showNoCoinsAlert("❌ Bạn đã nhận thưởng sự kiện này hôm nay rồi!")
                return
            end
            local baseReward = 100
            if string.match(event.reward, "x(%d+)") then
                baseReward = tonumber(string.match(event.reward, "x(%d+)")) * 100
            end
            if event.name:lower() == "hieuung" then baseReward = baseReward * 2 end
            local finalReward = baseReward * settings.Multiplier
            settings.Coins = settings.Coins + finalReward
            updateCoinsUI()
            saveVIPData()
            lastEventClaim[claimKey] = true
            showNoCoinsAlert("✅ Nhận thưởng thành công!\n+" .. formatCoins(finalReward) .. " Coins")
            EventHUDClaimBtn.Visible = false
            break
        end
    end
end)

-- Cập nhật HUD mỗi giây
task.spawn(function()
    while true do
        task.wait(1)
        updateEventHUD()
        CoinsHUDText.Text = "💸 " .. formatCoins(settings.Coins)
        if settings.Multiplier > 1 then
            CoinsHUDText.Text = CoinsHUDText.Text .. " (X" .. settings.Multiplier .. ")"
        end
        
        -- Big countdown
        local endTime, _ = getEventEndTime()
        if endTime then
            local remaining = endTime - os.time()
            if remaining > 0 and remaining <= 300 then
                BigCountdown.Visible = true
                BigCountdownTime.Text = formatCountdown(remaining)
                if remaining <= 60 then
                    BigCountdownTime.TextColor3 = Color3.fromRGB(255, 0, 0)
                else
                    BigCountdownTime.TextColor3 = Color3.fromRGB(255, 255, 0)
                end
            else
                BigCountdown.Visible = false
            end
        else
            BigCountdown.Visible = false
        end
    end
end)

