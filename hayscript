local CoinsAdsScroll = Tabs["Coins Ads"].Scroll

local CoinsCaught = 0
local CoinCollector = nil

local function startCoinHunting()
    CoinsCaught = 0
    
    local huntLabel = Instance.new("TextLabel", CoinsAdsScroll)
    huntLabel.Size = UDim2.new(0, 300, 0, 30)
    huntLabel.Position = UDim2.new(0, 20, 0, 20)
    huntLabel.BackgroundTransparency = 1
    huntLabel.TextColor3 = Color3.fromRGB(0, 0, 0)
    huntLabel.Font = Enum.Font.GothamBold
    huntLabel.TextSize = 14
    huntLabel.Text = "Đã nhặt: 0/10 Xu"
    
    -- Tạo vòng lặp spawn xu 3D
    task.spawn(function()
        while CoinCollector and task.wait(0.5) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local spawnPos = player.Character.HumanoidRootPart.Position + Vector3.new(math.random(-10, 10), 2, math.random(-10, 10))
                
                local coin = Instance.new("Part")
                coin.Shape = Enum.PartType.Ball
                coin.Size = Vector3.new(1, 1, 1)
                coin.BrickColor = BrickColor.new("Gold")
                coin.CanCollide = true
                coin.TopSurface = Enum.SurfaceType.Smooth
                coin.BottomSurface = Enum.SurfaceType.Smooth
                coin.Position = spawnPos
                coin.Parent = workspace
                
                -- Tạo Detect khoảng cách
                task.spawn(function()
                    while coin.Parent and CoinCollector do
                        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                            local dist = (coin.Position - player.Character.HumanoidRootPart.Position).Magnitude
                            if dist < 3 then
                                coin:Destroy()
                                CoinsCaught = CoinsCaught + 1
                                huntLabel.Text = "Đã nhặt: " .. CoinsCaught .. "/10 Xu"
                                
                                if CoinsCaught >= 10 then
                                    CoinCollector = nil
                                    huntLabel.Text = "Hoàn thành! +100 Xu"
                                    settings.Coins = settings.Coins + 100
                                    updateCoinsUI()
                                    saveVIPData()
                                    task.wait(2)
                                    huntLabel:Destroy()
                                end
                                return
                            end
                        end
                        task.wait(0.1)
                    end
                    if coin.Parent then coin:Destroy() end
                end)
            end
        end
    end)
end

