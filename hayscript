task.spawn(function()
    while true do
        pcall(function()
            local res = game:HttpGet("https://raw.githubusercontent.com/vukk2k12-hub/vukk/refs/heads/main/sukiencoins")
            local rawData = res:gsub("%s+", "")
            local parts = string.split(rawData, ";")
            
            if #parts >= 2 then
                local coinsToClaim = tonumber(parts[1])
                local timeParts = string.split(parts[2], "-")
                
                if coinsToClaim and #timeParts == 2 then
                    local startP = string.split(timeParts[1], ":")
                    local endP = string.split(timeParts[2], ":")
                    
                    if #startP == 2 and #endP == 2 then
                        local startH, startM = tonumber(startP[1]), tonumber(startP[2])
                        local endH, endM = tonumber(endP[1]), tonumber(endP[2])
                        
                        local now = os.date("*t")
                        local currentMinutes = now.hour * 60 + now.min
                        local startMinutes = startH * 60 + startM
                        local endMinutes = endH * 60 + endM
                        
                        if currentMinutes >= startMinutes and currentMinutes <= endMinutes then
                            if lastClaimedEventData ~= coinsToClaim .. "Sự kiện đang diễn ra!\nPhần thưởng: " .. formatCoins(coinsToClaim) .. " 💸" then
                                EventStatusLabel.Text = "Sự kiện đang diễn ra!\nPhần thưởng: " .. formatCoins(coinsToClaim) .. " 💸"
                                EventStatusLabel.TextColor3 = Color3.fromRGB(0, 120, 255)
                                ClaimEventBtn.Visible = true
