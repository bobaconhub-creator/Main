local function encryptData(data)
    local hex = ""
    for i = 1, #data do
        hex = hex .. string.format("%02X", string.byte(data, i) + 7) 
    end
    return "vippro_" .. hex
end

local function decryptData(data)
    if string.sub(data, 1, 7) == "vippro_" then
        local hex = string.sub(data, 8)
        local str = ""
        for i = 1, #hex, 2 do
            str = str .. string.char(tonumber(string.sub(hex, i, i+1), 16) - 7)
        end
        return str
    end
    return data 
end

