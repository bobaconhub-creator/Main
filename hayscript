local function spinWheel()
    if isSpinning then return end
    if #Rewards == 0 then
        showNoCoinsAlert("❌ Đang tải dữ liệu phần thưởng!")
        return
    end
    if settings.Coins < 500 then
        showNoCoinsAlert("❌ Bạn không đủ 500 Coins để quay!")
        return
    end
    
    isSpinning = true
    SpinBtn.Text = "🔄 ĐANG QUAY..."
    SpinBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    SpinBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    SpinBtn.Visible = false
    
    settings.Coins = settings.Coins - 500
    updateCoinsUI()
    saveVIPData()
    CoinsSpinLabel.Text = "💸 Coins: " .. formatCoins(settings.Coins) .. " | X" .. settings.Multiplier
    
    Wheel.Rotation = 0
    
    local totalPercent = 0
    local rand = math.random(1, 10000) / 100
    local selectedReward = nil
    local selectedIndex = 1
    
    for i, reward in ipairs(Rewards) do
        totalPercent = totalPercent + reward.percent
        if rand <= totalPercent then
            selectedReward = reward
            selectedIndex = i
            break
        end
    end
    
    if not selectedReward then
        selectedReward = Rewards[#Rewards]
        selectedIndex = #Rewards
    end
    
    local segmentAngle = 360 / #Rewards
    local targetAngle = (selectedIndex - 1) * segmentAngle + segmentAngle / 2
    local extraSpins = 5 + math.random(3, 8)
    local totalRotation = extraSpins * 360 + (360 - targetAngle) + math.random(-5, 5)
    
    local startTime = tick()
    local duration = 3 + math.random(1, 2)
    local startRotation = 0
    
    spinTween = game:GetService("RunService").RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        local progress = math.min(elapsed / duration, 1)
        local easeOut = 1 - (1 - progress) * (1 - progress)
        local currentRotation = totalRotation * easeOut
        
        Wheel.Rotation = currentRotation
        
        if progress < 1 then
            local randomReward = Rewards[math.random(1, #Rewards)]
            ResultLabel.Text = "🎰 " .. randomReward.coins
            ResultLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
            WheelContainer.BackgroundColor3 = Color3.fromRGB(
                math.random(50, 200),
                math.random(50, 200),
                math.random(50, 200)
            )
        else
            spinTween:Disconnect()
            
            local gain = selectedReward.coins * settings.Multiplier
            settings.Coins = settings.Coins + gain
            updateCoinsUI()
            saveVIPData()
            CoinsSpinLabel.Text = "💸 Coins: " .. formatCoins(settings.Coins) .. " | X" .. settings.Multiplier
            
            ResultLabel.Text = "🎉 +" .. gain .. " 🪙"
            ResultLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            WheelContainer.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            
            pcall(function()
                StarterGui:SetCore("SendNotification", {
                    Title = "🎉 Chúc mừng!",
                    Text = "Bạn nhận được " .. gain .. " Coins! (X"..settings.Multiplier..")",
                    Duration = 3,
                })
            end)
            
            task.wait(1.5)
            
            SpinBtn.Visible = true
            SpinBtn.Text = "🎰 QUAY NGAY (500 💸)"
            SpinBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            SpinBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            WheelContainer.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            ResultLabel.Text = "🎰 QUAY"
            ResultLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            isSpinning = false
        end
    end)
end

