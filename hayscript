local function updateAFKUI()
    if settings.AFK.IsUnlocked then
        AFKStatusLabel.Text = "🟢 ĐÃ MỞ KHÓA - ĐANG HOẠT ĐỘNG"
        AFKStatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        
        local elapsed = os.time() - settings.AFK.StartTime
        AFKTimeLabel.Text = "⏱️ Đã chạy: " .. formatTime(elapsed)
        
        AFKCoinsLabel.Text = "💰 Xu AFK đã kiếm: " .. formatCoins(settings.AFK.CoinsEarned) .. " 💸"
        
        BuyAFKFrame.Visible = false
        UnlockedFrame.Visible = true
    else
        AFKStatusLabel.Text = "🔴 CHƯA MỞ KHÓA"
        AFKStatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        AFKTimeLabel.Text = "⏱️ Chưa kích hoạt"
        AFKCoinsLabel.Text = "💰 Xu AFK đã kiếm: 0 💸"
        
        BuyAFKFrame.Visible = true
        UnlockedFrame.Visible = false
    end
end

local function buyAFK()
    if settings.AFK.IsUnlocked then
        return false, "Bạn đã mở khóa AFK rồi!"
    end
    
    if settings.Coins < 2000 then
        return false, "Không đủ Coins! Cần 2,000 💸"
    end
    
    settings.Coins = settings.Coins - 2000
    updateCoinsUI()
    saveVIPData()
    
    settings.AFK.IsUnlocked = true
    settings.AFK.StartTime = os.time()
    settings.AFK.LastSavedTime = os.time()
    settings.AFK.CoinsEarned = 0
    settings.AFK.TotalTime = 0
    
    saveAFKData()
    updateAFKUI()
    
    return true, "🎉 Mở khóa AFK thành công!"
end

