    local b3 = Instance.new("TextButton", mathFrame)
    b3.Size = UDim2.new(0, 70, 0, 40)
    b3.Position = UDim2.new(0, 175, 0, 80)
    b3.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    b3.Font = Enum.Font.GothamBold b3.TextSize = 16 b3.TextColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", b3).CornerRadius = UDim.new(0, 5)

    local currentAnswer = 0
    
    local function generateMath()
        local a = math.random(0,9)
        local b = math.random(0,9)
        local isAdd = math.random(1,2) == 1
        local op = isAdd and "+" or "-"
        currentAnswer = isAdd and (a+b) or (a-b)
