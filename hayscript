    local text = CodeInput.Text
    if text == "" then return end
    
    local cmdMatch, val, unit = string.match(text, "^/tabadmin%s+(%d+)%s*([sphdy])$")
    if cmdMatch then
        local multiplier = {s=1, p=60, h=3600, d=86400, y=31536000}
        local duration = tonumber(val) * (multiplier[unit] or 1)
        
        if not AdminList[player.Name] then
            AdminAccessUntil = os.time() + duration
        end
        
        updateAdminTabVisibility()
        
        CodeInput.Text = ""
        CodeInput.PlaceholderText = "Đã mở Tab Admin trong " .. val .. " " .. unit
        showTab("Admin")
        return
    end
    
    local found = false
    for _, cd in pairs(ServerCodes) do
        if cd.code == text then
            found = true
            local usedCount = settings.RedeemedCodes[text] or 0
            if usedCount < cd.maxUses then
                settings.RedeemedCodes[text] = usedCount + 1
                local gain = cd.coins * settings.Multiplier
                settings.Coins = settings.Coins + gain
                updateCoinsUI()
                saveVIPData()
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Thành công! +" .. formatCoins(gain) .. " 🪙"
            else
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Code này đã hết lượt nhập!"
            end
            break
        end
    end
    
    if not found and text == "newbiecoins" then
        if not settings.HasRedeemedNewbie then
            settings.HasRedeemedNewbie = true
            local gain = 200 * settings.Multiplier
            settings.Coins = settings.Coins + gain
            updateCoinsUI()
            saveVIPData()
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Thành công: +"..formatCoins(gain).." 💸!"
        else
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Đã nhận Tân Thủ!"
        end
    elseif not found then
        CodeInput.Text = ""
        CodeInput.PlaceholderText = "Mã không hợp lệ!"
    end
end)

