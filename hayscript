        settings.Diamonds = settings.Diamonds + addKC
        settings.Coins = settings.Coins - (addKC * KC_LIMIT)
    end
    
    CoinsLabel.Text = "💸 Coins: " .. formatCoins(settings.Coins) .. " | 💎 KC: " .. formatCoins(settings.Diamonds)
    if settings.Multiplier > 1 then
        CoinsLabel.Text = CoinsLabel.Text .. " (X" .. settings.Multiplier .. ")"
    end
end
