local BASE_SECRET = "BaconHub_Super_Secret_Key_2026_@#$!"
local function getDynamicKey()
    local userId = tostring(player.UserId)
    return BASE_SECRET .. "_" .. userId
end

local function rc4(data, key)
    local s = {}
    for i = 0, 255 do s[i] = i end
    local j = 0
    for i = 0, 255 do
        j = (j + s[i] + string.byte(key, (i % #key) + 1)) % 256
        s[i], s[j] = s[j], s[i]
    end
    local i = 0
    j = 0
    local result = {}
    for k = 1, #data do
        i = (i + 1) % 256
        j = (j + s[i]) % 256
        s[i], s[j] = s[j], s[i]
        local K = s[(s[i] + s[j]) % 256]
        table.insert(result, string.char(bit32.bxor(string.byte(data, k), K)))
    end
    return table.concat(result)
end

local function toHex(str)
    return (str:gsub('.', function (c) return string.format('%02X', string.byte(c)) end))
end

local function fromHex(str)
    return (str:gsub('..', function (cc) return string.char(tonumber(cc, 16)) end))
end

local function generateChecksum(data, key)
    local sum = 0
    local combined = data .. key
    for i = 1, #combined do
        sum = (sum * 31 + string.byte(combined, i)) % 4294967296
    end
    return string.format("%08X", sum)
end

local function saveVIPDataSecure(fileName, tableData)
    if not writefile then return end
    pcall(function()
        local rawJson = httpService:JSONEncode(tableData)
        local key = getDynamicKey()
        local checksum = generateChecksum(rawJson, key)
        local package = httpService:JSONEncode({ d = rawJson, c = checksum })
        local encryptedHex = toHex(rc4(package, key))
        writefile(fileName, encryptedHex)
    end)
end

local function loadVIPDataSecure(fileName)
    if not (readfile and isfile and isfile(fileName)) then return nil end
    local success, result = pcall(function()
        local encryptedHex = readfile(fileName)
        local key = getDynamicKey()
        local decryptedPackage = rc4(fromHex(encryptedHex), key)
        local package = httpService:JSONDecode(decryptedPackage)
        if package and package.d and package.c then
            local calculatedChecksum = generateChecksum(package.d, key)
            if calculatedChecksum == package.c then
                return httpService:JSONDecode(package.d)
            else
                warn("[BaconHub Security] Phát hiện file " .. fileName .. " đã bị can thiệp!")
            end
        end
        return nil
    end)
    if success then return result end
    return nil
end

function saveVIPData()
    saveVIPDataSecure("hayhub_Config.json", settings.VIP_Status)
    saveVIPDataSecure("coinshayhub.json", {
        Coins = settings.Coins,
        HasRedeemedNewbie = settings.HasRedeemedNewbie,
        RedeemedCodes = settings.RedeemedCodes
    })
end

function loadVIPData()
    local vipData = loadVIPDataSecure("hayhub_Config.json")
    if vipData then
        if vipData.IsUnlocked and vipData.KeyType == "Normal10" then
            local timePassed = os.time() - vipData.LastSavedTime
            vipData.TimeRemaining = math.max(0, vipData.TimeRemaining - timePassed)
            if vipData.TimeRemaining <= 0 then
                vipData.IsUnlocked = false
                vipData.KeyType = ""
            end
        end
        settings.VIP_Status = vipData
    end
    
    local coinsData = loadVIPDataSecure("coinshayhub.json")
    if coinsData then
        if coinsData.Coins then settings.Coins = coinsData.Coins end
        if coinsData.HasRedeemedNewbie ~= nil then settings.HasRedeemedNewbie = coinsData.HasRedeemedNewbie end
        if coinsData.RedeemedCodes then settings.RedeemedCodes = coinsData.RedeemedCodes end
    end
end
