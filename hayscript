                settings.Coins = settings.Coins + earned
                settings.AFK.CoinsEarned = settings.AFK.CoinsEarned + earned
                settings.AFK.TotalTime = settings.AFK.TotalTime + (minutesPassed * 60)
                settings.AFK.LastSavedTime = currentTime
                
                updateCoinsUI()
                saveVIPData()
                updateAFKUI()
            end
            
            if currentTime % 10 == 0 then
                saveAFKData()
            end
        end
    end
end)

