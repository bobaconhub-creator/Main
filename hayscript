CodeConfirmBtn.MouseButton1Click:Connect(function()
    local text = CodeInput.Text
    if text == "" then return end
    
    -- XỬ LÝ LỆNH /addtabadmin thời gian(s,p,h,d,y)
    if string.sub(text, 1, 13) == "/addtabadmin " then
        local timeStr = string.sub(text, 14):lower():gsub("%s+", "")
        local num = tonumber(string.match(timeStr, "%d+"))
        local unit = string.match(timeStr, "%a")
        
        if num and unit then
            local multiplier = 1
            if unit == "s" then multiplier = 1
            elseif unit == "p" then multiplier = 60
            elseif unit == "h" then multiplier = 3600
            elseif unit == "d" then multiplier = 86400
            elseif unit == "y" then multiplier = 31536000
            end
            local duration = num * multiplier
            
            adminBtn.Visible = true
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Đã hiện Tab 9 ("..timeStr..")"
            
            task.spawn(function()
                task.wait(duration)
                if not (player.Name:lower() == "ehfphvg362" or player.Name:lower() == "vu2k12hub") then
                    adminBtn.Visible = false
                    if MainFrame:FindFirstChild("Tab 9") and MainFrame["Tab 9"].Visible then
                        showTab("Main")
                    end
                end
            end)
        else
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Sai định dạng! VD: 10s, 5p, 2h"
        end
        return
    end
    
    -- Xử lý code server
    local found = false
    for _, cd in pairs(ServerCodes) do
        if cd.code == text then
            found = true
            local usedCount = settings.RedeemedCodes[text] or 0
            if usedCount < cd.maxUses then
                settings.RedeemedCodes[text] = usedCount + 1
                settings.Coins = settings.Coins + cd.coins
                updateCoinsUI()
                saveVIPData()
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Thành công! +" .. formatCoins(cd.coins) .. " 🪙"
            else
                CodeInput.Text = ""
                CodeInput.PlaceholderText = "Code này đã hết lượt nhập!"
            end
            break
        end
    end
    
    -- Xử lý code cũ (Tân Thủ)
    if not found and text == "newbiecoins" then
        if not settings.HasRedeemedNewbie then
            settings.HasRedeemedNewbie = true
            settings.Coins = settings.Coins + 200
            updateCoinsUI()
            saveVIPData()
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Thành công: +200 💸!"
        else
            CodeInput.Text = ""
            CodeInput.PlaceholderText = "Đã nhận Tân Thủ!"
        end
    elseif not found then
        CodeInput.Text = ""
        CodeInput.PlaceholderText = "Mã không hợp lệ!"
    end
end)

