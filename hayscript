AdminExecuteBtn.MouseButton1Click:Connect(function()
    local amount = tonumber(AdminAmountBox.Text)
    if not amount or amount < 0 then return end
    
    if AdminState.IsCoins then
        if AdminState.IsAdd then settings.Coins = settings.Coins + amount
        else settings.Coins = math.max(0, settings.Coins - amount) end
    else
        if AdminState.IsAdd then settings.Diamonds = settings.Diamonds + amount
        else settings.Diamonds = math.max(0, settings.Diamonds - amount) end
    end
    
    updateCoinsUI()
    saveVIPData()
    AdminAmountBox.Text = ""
    AdminExecuteBtn.Text = "✅ ĐÃ THỰC THI THÀNH CÔNG ✅"
    task.wait(1.5)
    AdminExecuteBtn.Text = "🚀 THỰC THI (GỬI LỆNH) 🚀"
end)
