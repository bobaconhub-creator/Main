    Instance.new("UICorner", b1).CornerRadius = UDim.new(0, 5)
    
    local b2 = Instance.new("TextButton", mathFrame)
    b2.Size = UDim2.new(0, 70, 0, 40)
    b2.Position = UDim2.new(0, 95, 0, 80)
    b2.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    b2.Font = Enum.Font.GothamBold b2.TextSize = 16 b2.TextColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", b2).CornerRadius = UDim.new(0, 5)
    
    local b3 = Instance.new("TextButton", mathFrame)
    b3.Size = UDim2.new(0, 70, 0, 40)
    b3.Position = UDim2.new(0, 175, 0, 80)
    b3.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    b3.Font = Enum.Font.GothamBold b3.TextSize = 16 b3.TextColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", b3).CornerRadius = UDim.new(0, 5)

    local currentAnswer = 0
    
    local function generateMath()
        local a = math.random(1, 15)
        local b = math.random(1, 15)
        local isAdd = math.random(1, 2) == 1
        local op = isAdd and "+" or "-" 
        currentAnswer = isAdd and (a + b) or (a - b) 
        
        eqLabel.Text = a .. " " .. op .. " " .. b .. " = ?"
        streakLabel.Text = "Tiến độ: " .. streak .. "/4"
        
        local options = {currentAnswer, currentAnswer + math.random(1,3), currentAnswer - math.random(1,3)}
        
        for i = #options, 2, -1 do
            local j = math.random(i)
            options[i], options[j] = options[j], options[i]
        end
        b1.Text = tostring(options[1])
        b2.Text = tostring(options[2])
        b3.Text = tostring(options[3])
    end
    
    local function handleAnswer(selected)
        if tonumber(selected) == currentAnswer then
            streak = streak + 1
            if streak >= 4 then
                streak = 0
                settings.Coins = settings.Coins + 40
                updateCoinsUI()
                saveVIPData()
                streakLabel.Text = "Bạn nhận được 40 💸!"
                task.wait(0.5)
            end
        else
            streak = 0
            streakLabel.Text = "Sai! Bắt đầu lại."
            task.wait(0.5)
        end
        generateMath()
    end
    
    b1.MouseButton1Click:Connect(function() handleAnswer(b1.Text) end)
    b2.MouseButton1Click:Connect(function() handleAnswer(b2.Text) end)
    b3.MouseButton1Click:Connect(function() handleAnswer(b3.Text) end)
    
    createCloseX(mathFrame, function()
        mathFrame:Destroy()
