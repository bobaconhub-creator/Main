-- 4. CƠ CHẾ AURA SEAT VOID (NÚT 3)
-- ==========================================
local isAuraSeatEnabled = false
local auraSeatLoop = nil
local auraRadius = 25 -- Bán kính quét Player xung quanh
local activeSeats = {} -- Lưu trữ danh sách ghế đã tạo ra để quản lý

-- Hàm tìm kiếm một Part hợp lệ có sẵn trong map để chuyển đổi
local function findAvailablePart()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Part") and obj.CanCollide and not obj.Anchored and obj.Size.Magnitude > 1 then
			if not obj:FindFirstAncestorOfClass("Model") or not Players:GetPlayerFromCharacter(obj:FindFirstAncestorOfClass("Model")) then
				-- Đảm bảo Part không thuộc về bất kỳ người chơi nào và chưa bị biến thành ghế
				if not obj:IsA("Seat") and not activeSeats[obj] then
					return obj
				end
			end
		end
	end
	return nil
end

local function executeAuraSeat()
	local myChar = localPlayer.Character
	if not myChar then return end
	local myHrp = myChar:FindFirstChild("HumanoidRootPart")
	if not myHrp then return end

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer and p.Character then
			local enemyHrp = p.Character:FindFirstChild("HumanoidRootPart")
			local enemyHumanoid = p.Character:FindFirstChildOfClass("Humanoid")
			
			if enemyHrp and enemyHumanoid and enemyHumanoid.Health > 0 then
				-- Kiểm tra xem Player này đã ngồi (Seat) hoặc đã bị kéo đi chưa
				if enemyHumanoid.Sit == false then
					local distance = (myHrp.Position - enemyHrp.Position).Magnitude
					if distance <= auraRadius then
						
						-- Lấy 1 Part ngẫu nhiên có sẵn trong Workspace
						local targetPart = findAvailablePart()
						if targetPart then
							-- Biến đổi thuộc tính thành ghế tàng hình
							activeSeats[targetPart] = true
							targetPart.Transparency = 1
							targetPart.CanCollide = true
							
							-- Ép kiểu/Tạo thực thể Seat đè lên tọa độ Part nếu cần, hoặc di chuyển trực tiếp Part có sẵn
							local seat = Instance.new("Seat")
							seat.Size = Vector3.new(2, 1, 2)
							seat.Transparency = 1
							seat.CFrame = enemyHrp.CFrame * CFrame.new(0, -0.5, 0)
							seat.Parent = Workspace
							
							-- Lắng nghe sự kiện khi có mục tiêu ngồi vào ghế
							seat:GetPropertyChangedSignal("Occupant"):Connect(function()
								if seat.Occupant == enemyHumanoid then
									task.wait(0.05) -- Đợi đồng bộ hóa vật lý nhân vật
									seat.Anchored = true
									-- Dịch chuyển ghế thẳng xuống dưới -1000 trục Y mang theo Player
									seat.CFrame = CFrame.new(seat.Position.X, -1000, seat.Position.Z)
									
									-- Dọn dẹp đối tượng sau khi thực thi thành công
									task.wait(1)
									seat:Destroy()
								end
							end)
							
							-- Cơ chế dọn dẹp dự phòng nếu không ai ngồi sau 3 giây
							Debris:AddItem(seat, 3)
						end
					end
				end
			end
		end
	end
end

local function toggleAuraSeat(state)
	isAuraSeatEnabled = state
	if auraSeatLoop then auraSeatLoop:Disconnect() auraSeatLoop = nil end
	
	if isAuraSeatEnabled then
		toggleAuraSeatBtn.Text = "Aura Seat: ON"
		toggleAuraSeatBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
		
		auraSeatLoop = RunService.RenderStepped:Connect(function()
			executeAuraSeat()
		end)
	else
		toggleAuraSeatBtn.Text = "Aura Seat: OFF"
		toggleAuraSeatBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
		table.clear(activeSeats)
	end
end

toggleAuraSeatBtn.MouseButton1Click:Connect(function()
	toggleAuraSeat(not isAuraSeatEnabled)
end)

