-- ==========================================
-- XỬ LÝ LOGIC HOẠT ĐỘNG
-- ==========================================

local isFlingEnabled = true
local flingSpeed = 850 

local isFrozen = false
local isTouchFlinging = false
local touchFlingConnection = nil
local savedCFrame = nil

-- Logic 1: Bật/Tắt Fling (Grab)
toggleButton.MouseButton1Click:Connect(function()
	isFlingEnabled = not isFlingEnabled
	if isFlingEnabled then
		toggleButton.Text = "Fling: ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
	else
		toggleButton.Text = "Fling: OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
	end
end)

-- Logic 2: Giới hạn tốc độ TextBox
speedInput:GetPropertyChangedSignal("Text"):Connect(function()
	local numericText = speedInput.Text:gsub("%D", "")
	if numericText ~= "" then
		local num = tonumber(numericText)
		if num > 5000 then num = 5000 end
		flingSpeed = num
		speedInput.Text = tostring(num)
	else
		flingSpeed = 0
	end
end)

-- Logic 3: Đứng Yên cơ bản (Anchored)
freezeButton.MouseButton1Click:Connect(function()
	isFrozen = not isFrozen
	local character = localPlayer.Character
	
	if isFrozen then
		-- Tắt Touch Fling nếu đang bật (Hai tính năng xung đột nhau)
		if isTouchFlinging then
			isTouchFlinging = false
			touchFlingButton.Text = "Touch Fling: OFF"
			touchFlingButton.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
			if touchFlingConnection then touchFlingConnection:Disconnect() end
		end
		
		freezeButton.Text = "Đứng Yên (Anchor): ON"
		freezeButton.BackgroundColor3 = Color3.fromRGB(230, 120, 0)
	else
		freezeButton.Text = "Đứng Yên (Anchor): OFF"
		freezeButton.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
	end
	
	if character and character:FindFirstChild("HumanoidRootPart") then
		character.HumanoidRootPart.Anchored = isFrozen
	end
end)

-- Logic 4: Touch Fling (Đứng Im + Chạm Là Văng)
touchFlingButton.MouseButton1Click:Connect(function()
	isTouchFlinging = not isTouchFlinging
	local character = localPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	
	if isTouchFlinging then
		-- Tắt Đứng Yên cơ bản nếu đang bật
		if isFrozen then
			isFrozen = false
			freezeButton.Text = "Đứng Yên (Anchor): OFF"
			freezeButton.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
		end
		
		touchFlingButton.Text = "Touch Fling: ON"
		touchFlingButton.BackgroundColor3 = Color3.fromRGB(150, 0, 200) -- Màu Tím báo hiệu nguy hiểm
		
		if rootPart then
			rootPart.Anchored = false -- Bắt buộc phải tắt Anchor thì lực mới truyền sang người khác được
			savedCFrame = rootPart.CFrame
			
			-- Tạo BodyPosition để giữ nhân vật không bị bay đi
			local bp = Instance.new("BodyPosition")
			bp.Name = "TouchFlingBP"
			bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
			bp.Position = savedCFrame.Position
			bp.Parent = rootPart
			
			-- Vòng lặp bơm vận tốc ảo và khóa CFrame
			touchFlingConnection = RunService.Stepped:Connect(function()
				if character and character:FindFirstChild("HumanoidRootPart") then
					-- Lực xoay vật lý cực mạnh để tạo Fling
					character.HumanoidRootPart.RotVelocity = Vector3.new(50000, 50000, 50000)
					-- Ép hình ảnh nhân vật đứng im tại một vị trí
					character.HumanoidRootPart.CFrame = savedCFrame
				end
			end)
		end
	else
		touchFlingButton.Text = "Touch Fling: OFF"
		touchFlingButton.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
		
		if touchFlingConnection then
			touchFlingConnection:Disconnect()
			touchFlingConnection = nil
		end
		if rootPart then
			local bp = rootPart:FindFirstChild("TouchFlingBP")
			if bp then bp:Destroy() end
			rootPart.RotVelocity = Vector3.zero
		end
	end
end)

-- Xử lý khi nhân vật chết và Hồi sinh
localPlayer.CharacterAdded:Connect(function(character)
	task.wait(0.5)
	
	-- Giữ trạng thái Đứng Yên (Anchor)
	if isFrozen and character:FindFirstChild("HumanoidRootPart") then
		character.HumanoidRootPart.Anchored = true
	end
	
	-- Tắt Touch Fling để tránh lỗi vật lý khi hồi sinh
	if isTouchFlinging then
		isTouchFlinging = false
		touchFlingButton.Text = "Touch Fling: OFF"
		touchFlingButton.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
		if touchFlingConnection then 
			touchFlingConnection:Disconnect()
			touchFlingConnection = nil
		end
	end
end)

-- Nút Đóng & Kéo Thả Menu (Giữ nguyên)
closeButton.MouseButton1Click:Connect(function() screenGui:Destroy() end)

local isDragging, dragStartPos, frameStartPos = false, nil, nil
mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = true
		dragStartPos = input.Position
		frameStartPos = mainFrame.Position
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStartPos
		mainFrame.Position = UDim2.new(frameStartPos.X.Scale, frameStartPos.X.Offset + delta.X, frameStartPos.Y.Scale, frameStartPos.Y.Offset + delta.Y)
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = false
	end
end)

-- Logic Fling GrabParts (Giữ nguyên)
Workspace.ChildAdded:Connect(function(child)
	if child.Name == "GrabParts" then
		local grabPart = child:FindFirstChild("GrabPart")
		if not grabPart then return end
		local weldConstraint = grabPart:FindFirstChild("WeldConstraint")
		if not weldConstraint or not weldConstraint.Part1 then return end
		local targetPart = weldConstraint.Part1
		local bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.Parent = targetPart
		
		child:GetPropertyChangedSignal("Parent"):Connect(function()
			if not child.Parent then
				if isFlingEnabled then
					bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
					bodyVelocity.Velocity = Workspace.CurrentCamera.CFrame.LookVector * flingSpeed
				else
					bodyVelocity.MaxForce = Vector3.zero
				end
				Debris:AddItem(bodyVelocity, 1)
			end
		end)
	end
end)
