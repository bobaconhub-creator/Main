-- 2. Giới hạn ô nhập tốc độ
speedInput:GetPropertyChangedSignal("Text"):Connect(function()
	local numericText = speedInput.Text:gsub("%D", "")
	if numericText ~= "" then
		local num = tonumber(numericText)
		if num > 5000 then num = 5000 end
		flingSpeed = num
		speedInput.Text = tostring(num)
	else
		flingSpeed = 0
	end
end)

-- 3. Hàm xử lý logic Anti-Grab Xịn (Nút 2)
local function ToggleAntiGrab(state)
	isAntiGrabEnabled = state
	
	if isAntiGrabEnabled then
		-- Sử dụng RunService.Stepped để xóa trước khi engine vật lý Roblox xử lý liên kết
		antiGrabConnection = RunService.Stepped:Connect(function()
			local character = localPlayer.Character
			if not character then return end
			
			-- Quét toàn bộ nhân vật để tìm và xóa mối hàn lạ từ kẻ địch dính vào mình
			for _, descendant in ipairs(character:GetDescendants()) do
				if descendant:IsA("Weld") or descendant:IsA("WeldConstraint") or descendant:IsA("AlignPosition") or descendant:IsA("AlignOrientation") then
					
					local p0 = descendant.Part0
					local p1 = descendant.Part1
					
					-- Kiểm tra xem mối nối có phải bắt nguồn từ bên ngoài nhân vật của bạn không
					local p0_is_mine = p0 and p0:IsDescendantOf(character)
					local p1_is_mine = p1 and p1:IsDescendantOf(character)
					
					if (p0 and not p0_is_mine) or (p1 and not p1_is_mine) then
						descendant:Destroy() -- Cắt đứt ngay lập tức mối tóm từ người khác
					end
				end
				
				-- Xóa các thư mục Grab mà game tự động gài vào người bạn để giữ
				if descendant:IsA("Folder") and descendant.Name:lower():match("grab") then
					descendant:Destroy()
				end
				
				-- Xóa các công cụ/lực đẩy lạ gài vào người bạn (Chống hack Fling từ người khác)
				if descendant:IsA("BodyVelocity") or descendant:IsA("LinearVelocity") or descendant:IsA("BodyThrust") or descendant:IsA("BodyAngularVelocity") then
					descendant:Destroy()
				end
			end
			
			-- Bảo hiểm chống bị văng do bug va chạm vật lý
			local rootPart = character:FindFirstChild("HumanoidRootPart")
			if rootPart then
				if rootPart.AssemblyLinearVelocity.Magnitude > 100 then
					rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				end
			end
		end)
	else
		-- Khi TẮT: Hủy bỏ vòng lặp kiểm tra
		if antiGrabConnection then
			antiGrabConnection:Disconnect()
			antiGrabConnection = nil
		end
	end
end

antiGrabButton.MouseButton1Click:Connect(function()
	isAntiGrabEnabled = not isAntiGrabEnabled
	ToggleAntiGrab(isAntiGrabEnabled)
	
	if isAntiGrabEnabled then
		antiGrabButton.Text = "Anti-Grab: ON"
		antiGrabButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0) -- Xanh lá khi bật
	else
		antiGrabButton.Text = "Anti-Grab: OFF"
		antiGrabButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0) -- Đỏ khi tắt
	end
end)

