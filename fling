local isFlingEnabled = true
local flingSpeed = 850 -- Biến lưu trữ tốc độ hiện tại
local isAntiGrabEnabled = false
local antiGrabConnection = nil

-- 1. Bật/Tắt Fling (Nút 1)
toggleButton.MouseButton1Click:Connect(function()
	isFlingEnabled = not isFlingEnabled
	if isFlingEnabled then
		toggleButton.Text = "Fling: ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
	else
		toggleButton.Text = "Fling: OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
	end
end)

-- 2. Giới hạn ô nhập tối đa 5000
speedInput:GetPropertyChangedSignal("Text"):Connect(function()
	local numericText = speedInput.Text:gsub("%D", "")
	if numericText ~= "" then
		local num = tonumber(numericText)
		if num > 5000 then
			num = 5000
		end
		flingSpeed = num
		speedInput.Text = tostring(num)
	else
		flingSpeed = 0
	end
end)

-- 3. Logic xử lý Bật/Tắt Anti-Grab (Nút 2)
local function ToggleAntiGrab(state)
	isAntiGrabEnabled = state
	if isAntiGrabEnabled then
		antiGrabConnection = RunService.RenderStepped:Connect(function()
			local character = localPlayer.Character
			if not character then return end
			
			-- Lớp 1 & 2: Quét dọn các liên kết và lực đẩy dính vào người mình
			for _, descendant in ipairs(character:GetDescendants()) do
				if descendant:IsA("Weld") or descendant:IsA("WeldConstraint") or descendant:IsA("Motor6D") then
					local part0 = descendant.Part0
					local part1 = descendant.Part1
					
					local owner0 = part0 and part0.Parent and Players:GetPlayerFromCharacter(part0.Parent)
					local owner1 = part1 and part1.Parent and Players:GetPlayerFromCharacter(part1.Parent)
					
					-- Nếu có ai khác hàn vào người mình, hủy liên kết ngay lập tức
					if (owner0 and owner0 ~= localPlayer) or (owner1 and owner1 ~= localPlayer) then
						descendant:Destroy()
					end
				end
				
				if descendant:IsA("BodyVelocity") or descendant:IsA("LinearVelocity") or descendant:IsA("BodyThrust") then
					descendant:Destroy()
				end
			end
			
			-- Lớp 3: Chống bị ném văng tốc độ cao
			local rootPart = character:FindFirstChild("HumanoidRootPart")
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			if rootPart and humanoid then
				if rootPart.AssemblyLinearVelocity.Magnitude > 75 then 
					rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
					humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
				end
			end
		end)
	else
		if antiGrabConnection then
			antiGrabConnection:Disconnect()
			antiGrabConnection = nil
		end
	end
end

antiGrabButton.MouseButton1Click:Connect(function()
	isAntiGrabEnabled = not isAntiGrabEnabled
	ToggleAntiGrab(isAntiGrabEnabled)
	
	if isAntiGrabEnabled then
		antiGrabButton.Text = "Anti-Grab: ON"
		antiGrabButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0) -- Đổi sang màu xanh lá khi bật
	else
		antiGrabButton.Text = "Anti-Grab: OFF"
		antiGrabButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0) -- Về màu đỏ khi tắt
	end
end)

