-- Biến lưu trạng thái hiển thị GUI
local isGUIVisible = true

-- Hàm toggle GUI
local function toggleGUI()
    isGUIVisible = not isGUIVisible
    screenGui.Enabled = isGUIVisible
end

-- Hàm toggle Fling
local function toggleFling()
    isFlingEnabled = not isFlingEnabled
    if isFlingEnabled then
        toggleFlingBtn.Text = "Fling: ON"
        toggleFlingBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        toggleFlingBtn.Text = "Fling: OFF"
        toggleFlingBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    end
end

-- Hàm toggle Anti-Grab
local function toggleAntiGrabFunc()
    toggleAntiGrab(not isAntiGrabEnabled)
end

-- Xử lý phím tắt
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- F1: Toggle GUI
    if input.KeyCode == Enum.KeyCode.F1 then
        toggleGUI()
    end
    
    -- F2: Toggle Fling
    if input.KeyCode == Enum.KeyCode.F2 then
        toggleFling()
    end
    
    -- F3: Toggle Anti-Grab
    if input.KeyCode == Enum.KeyCode.F3 then
        toggleAntiGrabFunc()
    end
end)

