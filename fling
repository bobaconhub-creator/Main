-- Kéo thả di chuyển UI
local isDragging = false
local dragStartPos, frameStartPos

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = true
		dragStartPos = input.Position
		frameStartPos = mainFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStartPos
		mainFrame.Position = UDim2.new(
			frameStartPos.X.Scale, frameStartPos.X.Offset + delta.X, 
			frameStartPos.Y.Scale, frameStartPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = false
	end
end)

-- ==========================================
-- 2. XỬ LÝ LOGIC FLING
-- ==========================================
local isFlingEnabled = true
local flingSpeed = 850

speedInput:GetPropertyChangedSignal("Text"):Connect(function()
	local numericText = speedInput.Text:gsub("%D", "")
	if numericText ~= "" then
		local num = tonumber(numericText)
		if num > 5000 then num = 5000 end
		flingSpeed = num
		speedInput.Text = tostring(num)
	else
		flingSpeed = 0
	end
end)

toggleFlingBtn.MouseButton1Click:Connect(function()
	isFlingEnabled = not isFlingEnabled
	if isFlingEnabled then
		toggleFlingBtn.Text = "Fling: ON"
		toggleFlingBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
	else
		toggleFlingBtn.Text = "Fling: OFF"
		toggleFlingBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
	end
end)

local childAddedConn = Workspace.ChildAdded:Connect(function(child)
	if child.Name == "GrabParts" then
		local grabPart = child:FindFirstChild("GrabPart")
		if not grabPart then return end
		local weldConstraint = grabPart:FindFirstChild("WeldConstraint")
		if not weldConstraint or not weldConstraint.Part1 then return end
		local targetPart = weldConstraint.Part1
		
		local bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.Parent = targetPart
		
		child:GetPropertyChangedSignal("Parent"):Connect(function()
			if not child.Parent then
				if isFlingEnabled then
					bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
					bodyVelocity.Velocity = Workspace.CurrentCamera.CFrame.LookVector * flingSpeed
				else
					bodyVelocity.MaxForce = Vector3.zero
				end
				Debris:AddItem(bodyVelocity, 100)
			end
		end)
	end
end)

-- ==========================================
-- 3. CƠ CHẾ ANTI-GRAB & ANTI-ROLL (NATIVE)
-- ==========================================
local isAntiGrabEnabled = false
local antiGrabLoop = nil

local function executeNativeAntiGrab()
	local char = localPlayer.Character
	if not char then return end
	
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")

	-- 3.1 CƠ CHẾ ANTI-ROLL (Giữ đứng thẳng & chống té ngã)
	if hrp and humanoid then
		-- Triệt tiêu các lực xoay không mong muốn gây lật nhân vật
		hrp.RotVelocity = Vector3.new(0, hrp.RotVelocity.Y, 0)
		
		-- Ép góc quay (CFrame) chỉ xoay quanh trục Y (giữ thăng bằng mặt đất)
		local _, yOrientation, _ = hrp.CFrame:ToOrientation()
		hrp.CFrame = CFrame.new(hrp.Position) * CFrame.fromOrientation(0, yOrientation, 0)
		
		-- Ngăn chặn các trạng thái té ngã (FallingDown, Ragdoll do game ép)
		if humanoid:GetState() == Enum.HumanoidStateType.FallingDown or humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then
			humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end

	-- 3.2 GỬI PACKET GIẢI PHÓNG KHI BỊ TÓM (Anti-Grab)
	if StruggleEvent then
		local isHeld = localPlayer:FindFirstChild("IsHeld")
		if isHeld and isHeld.Value == true then
			StruggleEvent:FireServer(localPlayer)
		end
	end
	
	-- 3.3 QUÉT LIÊN KẾT VẬT LÝ (Phòng thủ phụ)
	for _, obj in ipairs(char:GetDescendants()) do
		if obj:IsA("WeldConstraint") or obj:IsA("Weld") then
			local p0 = obj.Part0
			local p1 = obj.Part1
			if (p0 and p0.Name == "GrabPart") or (p1 and p1.Name == "GrabPart") then
				if StruggleEvent then
					StruggleEvent:FireServer(localPlayer)
				end
			end
		end
	end
end

local function toggleAntiGrab(state)
	isAntiGrabEnabled = state
	
	if antiGrabLoop then
		antiGrabLoop:Disconnect()
		antiGrabLoop = nil
	end
	
	if isAntiGrabEnabled then
		toggleAntiGrabBtn.Text = "Anti-Grab/Roll: ON"
		toggleAntiGrabBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
		
		-- Chạy liên tục để triệt tiêu góc nghiêng ngay lập tức
		antiGrabLoop = RunService.RenderStepped:Connect(function()
			executeNativeAntiGrab()
		end)
	else
		toggleAntiGrabBtn.Text = "Anti-Grab/Roll: OFF"
		toggleAntiGrabBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
	end
end

toggleAntiGrabBtn.MouseButton1Click:Connect(function()
	toggleAntiGrab(not isAntiGrabEnabled)
end)

