-- ==========================================
-- XỬ LÝ LOGIC HOẠT ĐỘNG
-- ==========================================

local isFlingEnabled = true
local flingSpeed = 850 -- Biến lưu trữ tốc độ hiện tại

-- 1. Bật/Tắt Fling
toggleButton.MouseButton1Click:Connect(function()
	isFlingEnabled = not isFlingEnabled
	if isFlingEnabled then
		toggleButton.Text = "Fling: ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
	else
		toggleButton.Text = "Fling: OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
	end
end)

-- 2. Giới hạn ô nhập tối đa 5000
speedInput:GetPropertyChangedSignal("Text"):Connect(function()
	-- Chỉ cho phép nhập số
	local numericText = speedInput.Text:gsub("%D", "")
	
	if numericText ~= "" then
		local num = tonumber(numericText)
		if num > 5000 then
			num = 5000 -- Ép về 5000 nếu vượt quá
		end
		flingSpeed = num
		speedInput.Text = tostring(num)
	else
		flingSpeed = 0 -- Nếu xóa hết chữ thì tốc độ về 0
	end
end)

-- 3. Nút đóng Menu
closeButton.MouseButton1Click:Connect(function()
	screenGui:Destroy()
end)

-- 4. Kéo thả di chuyển Menu (Drag GUI)
local isDragging = false
local dragStartPos
local frameStartPos

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = true
		dragStartPos = input.Position
		frameStartPos = mainFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStartPos
		mainFrame.Position = UDim2.new(
			frameStartPos.X.Scale, 
			frameStartPos.X.Offset + delta.X, 
			frameStartPos.Y.Scale, 
			frameStartPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = false
	end
end)

-- 5. Logic Fling đồng bộ theo tốc độ trong TextBox
Workspace.ChildAdded:Connect(function(child)
	if child.Name == "GrabParts" then
		local grabPart = child:FindFirstChild("GrabPart")
		if not grabPart then return end
		
		local weldConstraint = grabPart:FindFirstChild("WeldConstraint")
		if not weldConstraint or not weldConstraint.Part1 then return end
		
		local targetPart = weldConstraint.Part1
		local bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.Parent = targetPart
		
		child:GetPropertyChangedSignal("Parent"):Connect(function()
			if not child.Parent then
				if isFlingEnabled then
					bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
					-- Sử dụng biến flingSpeed đã được cập nhật từ TextBox thay cho số 850 cũ
					bodyVelocity.Velocity = Workspace.CurrentCamera.CFrame.LookVector * flingSpeed
				else
					bodyVelocity.MaxForce = Vector3.zero
				end
				Debris:AddItem(bodyVelocity, 1)
			end
		end)
	end
end)
